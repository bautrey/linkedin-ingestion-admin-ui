<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - LinkedIn Ingestion Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/app.css" rel="stylesheet">
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="sidebar-wrapper px-0">
                <%- include('../partials/sidebar') %>
            </div>
            
            <!-- Main Content -->
            <div class="main-content">
                <%- include('../partials/header', { pageTitle: title }) %>
                
                <div class="container-fluid py-4">
                    <!-- Breadcrumb -->
                    <nav aria-label="breadcrumb" class="mb-4">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Home</a></li>
                            <li class="breadcrumb-item"><a href="/candidates" class="text-decoration-none">Candidates</a></li>
                            <li class="breadcrumb-item active" aria-current="page"><%= candidate.key %></li>
                        </ol>
                    </nav>

                    <!-- Page Header -->
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div>
                            <h2 class="fw-bold mb-1">
                                <%= candidate.fullName || 'Unknown Candidate' %>
                                <span class="badge bg-primary ms-2"><%= candidate.key %></span>
                            </h2>
                            <p class="text-muted mb-0">
                                <% if (candidate.email) { %>
                                    <i class="bi bi-envelope me-1"></i> <%= candidate.email %>
                                <% } %>
                                <% if (candidate.phone) { %>
                                    <i class="bi bi-telephone ms-3 me-1"></i> <%= candidate.phone %>
                                <% } %>
                                <% if (candidate.region) { %>
                                    <i class="bi bi-geo-alt ms-3 me-1"></i> <%= candidate.region %>
                                <% } %>
                            </p>
                        </div>
                        <div class="d-flex gap-2">
                            <% if (candidate.linkedinUrl) { %>
                                <a href="<%= candidate.linkedinUrl %>" target="_blank" class="btn btn-outline-primary">
                                    <i class="bi bi-linkedin"></i> View LinkedIn
                                </a>
                                <button class="btn btn-success" onclick="processCandidate('<%= candidate.key %>')">
                                    <i class="bi bi-play-circle"></i> Process Candidate
                                </button>
                            <% } %>
                        </div>
                    </div>

                    <div class="row">
                        <!-- Left Column - Candidate Info -->
                        <div class="col-lg-8">
                            <!-- Basic Information Card -->
                            <div class="card shadow-sm mb-4">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">
                                        <i class="bi bi-person-circle me-2"></i>Basic Information
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label fw-medium">Full Name</label>
                                            <div class="form-control-plaintext"><%= candidate.fullName || 'Not specified' %></div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-medium">Email</label>
                                            <div class="form-control-plaintext">
                                                <% if (candidate.email) { %>
                                                    <a href="mailto:<%= candidate.email %>" class="text-decoration-none">
                                                        <%= candidate.email %>
                                                    </a>
                                                <% } else { %>
                                                    Not specified
                                                <% } %>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-medium">Phone</label>
                                            <div class="form-control-plaintext">
                                                <% if (candidate.phone) { %>
                                                    <a href="tel:<%= candidate.phone %>" class="text-decoration-none">
                                                        <%= candidate.phone %>
                                                    </a>
                                                <% } else { %>
                                                    Not specified
                                                <% } %>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-medium">Region</label>
                                            <div class="form-control-plaintext"><%= candidate.region || 'Not specified' %></div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-medium">LinkedIn Profile</label>
                                            <div class="form-control-plaintext">
                                                <% if (candidate.linkedinUrl) { %>
                                                    <a href="<%= candidate.linkedinUrl %>" target="_blank" class="text-decoration-none">
                                                        <i class="bi bi-linkedin text-primary"></i> View Profile
                                                    </a>
                                                <% } else { %>
                                                    Not available
                                                <% } %>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-medium">Created Date</label>
                                            <div class="form-control-plaintext">
                                                <% if (candidate.created) { %>
                                                    <%= new Date(candidate.created).toLocaleDateString('en-US', { 
                                                        year: 'numeric', 
                                                        month: 'long', 
                                                        day: 'numeric' 
                                                    }) %>
                                                <% } else { %>
                                                    Unknown
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Profile Data Card -->
                            <% if (profileData) { %>
                                <div class="card shadow-sm mb-4">
                                    <div class="card-header">
                                        <h5 class="card-title mb-0">
                                            <i class="bi bi-database me-2"></i>Profile Data
                                        </h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label class="form-label fw-medium">Profile ID</label>
                                                <div class="form-control-plaintext">
                                                    <code><%= profileData.id %></code>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label fw-medium">Current Score</label>
                                                <div class="form-control-plaintext">
                                                    <% if (profileData.score && profileData.score > 0) { %>
                                                        <span class="badge bg-success fs-6">
                                                            <i class="bi bi-star-fill"></i> <%= profileData.score %>
                                                        </span>
                                                    <% } else { %>
                                                        <span class="text-muted">Not scored yet</span>
                                                    <% } %>
                                                </div>
                                            </div>
                            <div class="col-12">
                                <label class="form-label fw-medium">Role Assessment</label>
                                <div class="form-control-plaintext">
                                    <% if (profileData && profileData.suggested_role) { %>
                                        <!-- Suggested Role Display -->
                                        <div class="role-assessment">
                                            <div class="row align-items-center">
                                                <div class="col-md-6">
                                                    <div class="d-flex align-items-center">
                                                        <span class="badge bg-primary fs-5 me-3">
                                                            <i class="bi bi-person-badge"></i> <%= profileData.suggested_role %>
                                                        </span>
                                                        <div>
                                                            <div class="fw-medium">Suggested Role</div>
                                                            <div class="small text-muted">Based on profile analysis</div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <button class="btn btn-outline-info btn-sm" onclick="runDetailedRoleAnalysis('<%= profileData.id %>')">
                                                        <i class="bi bi-graph-up"></i> Run Detailed Analysis
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <!-- Container for detailed results (populated by AJAX) -->
                                        <div id="detailed-compatibility-results" class="mt-3" style="display: none;"></div>
                                        
                                    <% } else { %>
                                        <span class="badge bg-warning fs-6">
                                            <i class="bi bi-question-circle"></i> Not Assessed
                                        </span>
                                        <div class="small text-muted mt-1">
                                            Role assessment not available. Profile may need to be processed.
                                            <% if (profileData && profileData.id) { %>
                                                <button class="btn btn-link btn-sm p-0 ms-2" onclick="runDetailedRoleAnalysis('<%= profileData.id %>')">
                                                    Run Analysis
                                                </button>
                                            <% } %>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                            
                            <!-- Detailed Scoring Results Section -->
                            <% if (profileData && profileData.score && profileData.score > 0) { %>
                                <div class="col-12">
                                    <label class="form-label fw-medium">Detailed Scoring Results</label>
                                    <div class="form-control-plaintext">
                                        <div class="scoring-results">
                                            <!-- Overall Score Display -->
                                            <div class="row mb-4">
                                                <div class="col-md-6">
                                                    <div class="card bg-success text-white">
                                                        <div class="card-body text-center">
                                                            <h2 class="display-4 fw-bold mb-0">
                                                                <%= profileData.score %>
                                                                <small class="fs-6">/10</small>
                                                            </h2>
                                                            <p class="mb-0">Overall Score</p>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <div class="card bg-primary text-white">
                                                        <div class="card-body text-center">
                                                            <h4 class="fw-bold mb-1">
                                                                <i class="bi bi-award me-2"></i><%= profileData.suggested_role || 'Unknown' %>
                                                            </h4>
                                                            <p class="mb-0">Suggested Role</p>
                                                            <% if (profileData.scoring_job_id) { %>
                                                                <small class="opacity-75">
                                                                    Job: <%= profileData.scoring_job_id.substring(0, 8) %>...
                                                                </small>
                                                            <% } %>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            
                                            <!-- Scoring Breakdown -->
                                            <% if (profileData.scoring_breakdown) { %>
                                                <div class="scoring-breakdown">
                                                    <h6 class="fw-bold mb-3">Scoring Breakdown</h6>
                                                    <% 
                                                    const scoringData = typeof profileData.scoring_breakdown === 'string' 
                                                        ? JSON.parse(profileData.scoring_breakdown) 
                                                        : profileData.scoring_breakdown;
                                                    %>
                                                    
                                                    <% if (scoringData.criteria && Array.isArray(scoringData.criteria)) { %>
                                                        <div class="row g-3">
                                                            <% scoringData.criteria.forEach((criterion, index) => { %>
                                                                <div class="col-md-6">
                                                                    <div class="card border-0 bg-light">
                                                                        <div class="card-body py-3">
                                                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                                                <h6 class="mb-0"><%= criterion.name || `Criterion ${index + 1}` %></h6>
                                                                                <span class="badge bg-<%= criterion.score >= 8 ? 'success' : criterion.score >= 6 ? 'warning' : 'danger' %> fs-6">
                                                                                    <%= criterion.score %>/10
                                                                                </span>
                                                                            </div>
                                                                            <% if (criterion.comments) { %>
                                                                                <p class="small text-muted mb-0"><%= criterion.comments %></p>
                                                                            <% } %>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            <% }); %>
                                                        </div>
                                                    <% } %>
                                                    
                                                    <!-- Overall Comments -->
                                                    <% if (scoringData.overall_comments) { %>
                                                        <div class="mt-4">
                                                            <h6 class="fw-bold mb-2">Overall Assessment</h6>
                                                            <div class="card border-0 bg-light">
                                                                <div class="card-body">
                                                                    <p class="mb-0"><%= scoringData.overall_comments %></p>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    <% } %>
                                                </div>
                                            <% } %>
                                            
                                            <!-- Scoring Job Information -->
                                            <div class="mt-4 p-3 bg-light rounded">
                                                <div class="row align-items-center">
                                                    <div class="col-md-8">
                                                        <small class="text-muted">Scoring Details</small>
                                                        <div class="fw-medium">
                                                            <% if (profileData.scoring_job_id) { %>
                                                                Scored by AI using <%= bestRole || 'CTO' %> role template
                                                            <% } else { %>
                                                                AI-generated score for <%= bestRole || 'CTO' %> role
                                                            <% } %>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-4 text-end">
                                                        <% if (profileData.scoring_job_id) { %>
                                                            <a href="/scoring/jobs/<%= profileData.scoring_job_id %>" class="btn btn-outline-primary btn-sm">
                                                                <i class="bi bi-eye"></i> View Job Details
                                                            </a>
                                                        <% } %>
                                                    </div>
                                                </div>
                                                <% if (profileData.score_updated_at || profileData.updated_at) { %>
                                                    <div class="mt-2">
                                                        <small class="text-muted">
                                                            <i class="bi bi-clock"></i> 
                                                            Scored on <%= new Date(profileData.score_updated_at || profileData.updated_at).toLocaleDateString('en-US', { 
                                                                year: 'numeric', 
                                                                month: 'short', 
                                                                day: 'numeric',
                                                                hour: '2-digit',
                                                                minute: '2-digit'
                                                            }) %>
                                                        </small>
                                                    </div>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% } %>
                            
                                            <div class="col-md-6">
                                                <label class="form-label fw-medium">Profile Created</label>
                                                <div class="form-control-plaintext">
                                                    <%= new Date(profileData.created_at).toLocaleDateString('en-US', { 
                                                        year: 'numeric', 
                                                        month: 'short', 
                                                        day: 'numeric',
                                                        hour: '2-digit',
                                                        minute: '2-digit'
                                                    }) %>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% } %>

                            <!-- Processing History -->
                            <% if (processingHistory && processingHistory.length > 0) { %>
                                <div class="card shadow-sm mb-4">
                                    <div class="card-header">
                                        <h5 class="card-title mb-0">
                                            <i class="bi bi-clock-history me-2"></i>Processing History
                                        </h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="timeline">
                                            <% processingHistory.forEach((job, index) => { %>
                                                <div class="timeline-item">
                                                    <div class="timeline-marker bg-<%= job.status === 'completed' ? 'success' : job.status === 'failed' ? 'danger' : 'primary' %>"></div>
                                                    <div class="timeline-content">
                                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                                            <h6 class="mb-0"><%= job.type || 'Processing Job' %></h6>
                                                            <small class="text-muted">
                                                                <%= new Date(job.created_at).toLocaleDateString() %>
                                                            </small>
                                                        </div>
                                                        <div class="mb-2">
                                                            <span class="badge bg-<%= job.status === 'completed' ? 'success' : job.status === 'failed' ? 'danger' : 'primary' %>">
                                                                <%= job.status %>
                                                            </span>
                                                        </div>
                                                        <% if (job.result || job.error) { %>
                                                            <div class="small text-muted">
                                                                <%= job.result || job.error %>
                                                            </div>
                                                        <% } %>
                                                    </div>
                                                </div>
                                            <% }); %>
                                        </div>
                                    </div>
                                </div>
                            <% } %>
                        </div>

                        <!-- Right Column - Status & Actions -->
                        <div class="col-lg-4">
                            <!-- Status Card -->
                            <div class="card shadow-sm mb-4">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">
                                        <i class="bi bi-info-circle me-2"></i>Status Information
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <label class="form-label fw-medium">Jira Status</label>
                                        <div>
                                            <span class="badge bg-<%= candidate.status === 'Open' ? 'primary' : candidate.status === 'In Progress' ? 'warning' : 'success' %> fs-6">
                                                <%= candidate.status || 'Unknown' %>
                                            </span>
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-medium">Standing</label>
                                        <div>
                                            <% if (candidate.standing) { %>
                                                <span class="badge bg-<%= candidate.standing.includes('Excellent') ? 'success' : candidate.standing.includes('Good') || candidate.standing.includes('Qualified') ? 'info' : 'secondary' %> fs-6">
                                                    <%= candidate.standing %>
                                                </span>
                                            <% } else { %>
                                                <span class="text-muted">Not set</span>
                                            <% } %>
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-medium">Assignee</label>
                                        <div class="form-control-plaintext">
                                            <%= candidate.assignee || 'Unassigned' %>
                                        </div>
                                    </div>
                                    <div class="mb-0">
                                        <label class="form-label fw-medium">Reporter</label>
                                        <div class="form-control-plaintext">
                                            <%= candidate.reporter || 'Unknown' %>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Processing Status Card -->
                            <div class="card shadow-sm mb-4">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">
                                        <i class="bi bi-gear me-2"></i>Processing Status
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="me-3">
                                            <% const statusBadge = candidate.statusBadge || {text: 'Unknown', class: 'badge-secondary', icon: 'bi bi-question'}; %>
                                            <span class="badge <%= statusBadge.class %> fs-6">
                                                <i class="<%= statusBadge.icon %> me-1"></i>
                                                <%= statusBadge.text %>
                                            </span>
                                        </div>
                                    </div>
                                    
                                    <!-- Processing Steps -->
                                    <div class="processing-steps">
                                        <div class="step <%= candidate.hasLinkedIn ? 'completed' : 'pending' %>">
                                            <i class="bi bi-<%= candidate.hasLinkedIn ? 'check-circle-fill' : 'circle' %>"></i>
                                            <span>LinkedIn Profile Available</span>
                                        </div>
                                        <div class="step <%= candidate.hasProfile ? 'completed' : 'pending' %>">
                                            <i class="bi bi-<%= candidate.hasProfile ? 'check-circle-fill' : 'circle' %>"></i>
                                            <span>Profile Ingested</span>
                                        </div>
                                        <div class="step" id="compatibility-step">
                                            <i class="bi bi-circle" id="compatibility-icon"></i>
                                            <span>Compatibility Checked</span>
                                        </div>
                                        <div class="step <%= profileData && profileData.score && profileData.score > 0 ? 'completed' : 'pending' %>">
                                            <i class="bi bi-<%= profileData && profileData.score && profileData.score > 0 ? 'check-circle-fill' : 'circle' %>"></i>
                                            <span>Scored</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Actions Card -->
                            <div class="card shadow-sm">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">
                                        <i class="bi bi-lightning me-2"></i>Actions
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="d-grid gap-2">
                                        <% if (candidate.linkedinUrl) { %>
                                            <button class="btn btn-primary" 
                                                    onclick="processCandidate('<%= candidate.key %>')"
                                                    title="Run full processing pipeline: verify LinkedIn, ingest data, check role compatibility, and score"
                                                    data-bs-toggle="tooltip" 
                                                    data-bs-placement="top">
                                                <i class="bi bi-play-circle me-2"></i>Process All Steps
                                            </button>
                                            <button class="btn btn-outline-primary" 
                                                    onclick="ingestProfile('<%= candidate.key %>')"
                                                    title="Verify LinkedIn URL and ingest profile data only (no compatibility check or scoring)"
                                                    data-bs-toggle="tooltip" 
                                                    data-bs-placement="top">
                                                <i class="bi bi-download me-2"></i>Ingest Profile Only
                                            </button>
                                            <% if (profileData && profileData.role_compatibility_checked && profileData.compatibility_passed) { %>
                                                <button class="btn btn-outline-success" 
                                                        onclick="scoreCandidate('<%= candidate.key %>')"
                                                        title="Score this candidate using AI evaluation templates"
                                                        data-bs-toggle="tooltip" 
                                                        data-bs-placement="top">
                                                    <i class="bi bi-star me-2"></i>Score Candidate
                                                </button>
                                            <% } %>
                                        <% } else { %>
                                            <div class="alert alert-warning mb-0">
                                                <i class="bi bi-exclamation-triangle me-2"></i>
                                                No LinkedIn profile available for processing.
                                            </div>
                                        <% } %>
                                        
                                        <hr>
                                        
                                        <a href="/candidates" class="btn btn-outline-secondary">
                                            <i class="bi bi-arrow-left me-2"></i>Back to Candidates
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <!-- Toast Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" id="toast-container">
        <!-- Toasts will be dynamically added here -->
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Initialize Bootstrap tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });

        // Global variables
        let currentProcessingRequest;
        
        // Check for client-side compatibility status
        function updateCompatibilityStatus() {
            const candidateKey = '<%= candidate.key %>';
            const hasServerCompatibility = <%= profileData && profileData.role_compatibility_checked ? 'true' : 'false' %>;
            const hasClientCompatibility = localStorage.getItem(`compatibility_${candidateKey}`);
            
            if (hasServerCompatibility || hasClientCompatibility) {
                const step = document.getElementById('compatibility-step');
                const icon = document.getElementById('compatibility-icon');
                
                if (step && icon) {
                    step.classList.remove('pending');
                    step.classList.add('completed');
                    icon.classList.remove('bi-circle');
                    icon.classList.add('bi-check-circle-fill');
                }
            }
        }
        
        // Update status on page load
        updateCompatibilityStatus();

        // Toast notification system
        function showToast(message, type = 'info', duration = 5000) {
            const toastContainer = document.getElementById('toast-container');
            const toastId = 'toast-' + Date.now();
            
            const iconMap = {
                'success': 'bi-check-circle-fill',
                'error': 'bi-x-circle-fill',
                'warning': 'bi-exclamation-triangle-fill',
                'info': 'bi-info-circle-fill'
            };
            
            const toast = document.createElement('div');
            toast.id = toastId;
            toast.className = `toast align-items-center text-bg-${type} border-0`;
            toast.setAttribute('role', 'alert');
            toast.innerHTML = `
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="bi ${iconMap[type]} me-2"></i>
                        ${message}
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            `;
            
            toastContainer.appendChild(toast);
            
            const bsToast = new bootstrap.Toast(toast, {
                autohide: duration > 0,
                delay: duration
            });
            
            bsToast.show();
            
            // Remove from DOM after hiding
            toast.addEventListener('hidden.bs.toast', function() {
                toast.remove();
            });
            
            return bsToast;
        }

        // Process candidate - honest approach without fake progress
        async function processCandidate(candidateKey) {
            if (!confirm('Start processing pipeline? This may take 30-60 seconds for AI operations.')) return;
            
            // Show simple loading toast
            const loadingToast = showToast('Processing started... This may take up to 2 minutes.', 'info', 0); // Don't auto-hide
            
            try {
                const startTime = Date.now();
                const timeoutMs = 90000; // 90 second timeout
                
                const controller = new AbortController();
                currentProcessingRequest = controller;
                
                // Set up timeout
                const timeoutId = setTimeout(() => {
                    controller.abort();
                }, timeoutMs);
                
                const response = await fetch(`/api/candidates/${candidateKey}/process`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ actions: ['verify', 'ingest', 'check_compatibility', 'score'] }),
                    signal: controller.signal
                });
                
                clearTimeout(timeoutId);
                
                if (!response.ok) {
                    throw new Error(`Server error: ${response.status}`);
                }
                
                const data = await response.json();
                const elapsed = ((Date.now() - startTime) / 1000).toFixed(1);
                
                // Hide loading toast
                loadingToast.hide();
                
                if (data.success) {
                    // Save compatibility status if completed
                    const compatibilityStep = data.steps.find(step => step.step === 'check_compatibility');
                    if (compatibilityStep && compatibilityStep.success) {
                        localStorage.setItem(`compatibility_${candidateKey}`, Date.now().toString());
                    }
                    
                    const successCount = data.steps.filter(s => s.success).length;
                    const failCount = data.steps.filter(s => !s.success).length;
                    
                    showToast(`Processing completed in ${elapsed}s: ${successCount} successful, ${failCount} failed. Page will reload.`, 'success', 3000);
                    
                    setTimeout(() => {
                        location.reload();
                    }, 3000);
                    
                } else {
                    throw new Error(data.error || 'Processing failed');
                }
                
            } catch (error) {
                // Hide loading toast
                loadingToast.hide();
                
                if (error.name === 'AbortError') {
                    showToast('Processing timed out after 90 seconds. The operation may still be running in the background.', 'warning', 8000);
                } else {
                    showToast(`Processing failed: ${error.message}`, 'error', 8000);
                }
                
                console.error('Processing error:', error);
            } finally {
                currentProcessingRequest = null;
            }
        }
        
        function getStepSuccessMessage(stepName, stepResult) {
            switch(stepName) {
                case 'verify':
                    return 'LinkedIn URL verified successfully';
                case 'ingest':
                    return stepResult.data?.message || 'Profile data processed successfully';
                case 'check_compatibility':
                    return 'Role compatibility analysis completed';
                case 'score':
                    return 'AI scoring completed successfully';
                default:
                    return `${stepName} completed successfully`;
            }
        }

        // Ingest profile - honest approach
        async function ingestProfile(candidateKey) {
            if (!confirm('Ingest profile data? This usually takes 10-30 seconds.')) return;
            
            const loadingToast = showToast('Ingesting profile data...', 'info', 0);
            
            try {
                const response = await fetch(`/api/candidates/${candidateKey}/process`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ actions: ['verify', 'ingest'] })
                });
                
                loadingToast.hide();
                
                if (!response.ok) {
                    throw new Error(`Server error: ${response.status}`);
                }
                
                const data = await response.json();
                
                if (data.success) {
                    showToast('Profile ingestion completed successfully!', 'success');
                    setTimeout(() => location.reload(), 2000);
                } else {
                    throw new Error(data.error || 'Ingestion failed');
                }
                
            } catch (error) {
                loadingToast.hide();
                showToast(`Ingestion failed: ${error.message}`, 'error');
                console.error('Ingestion error:', error);
            }
        }

        // Score candidate - honest approach  
        async function scoreCandidate(candidateKey) {
            if (!confirm('Score this candidate? AI scoring can take 30-60 seconds.')) return;
            
            const loadingToast = showToast('AI scoring in progress... This may take up to 60 seconds.', 'info', 0);
            
            try {
                const response = await fetch(`/api/candidates/${candidateKey}/process`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ actions: ['score'] })
                });
                
                loadingToast.hide();
                
                if (!response.ok) {
                    throw new Error(`Server error: ${response.status}`);
                }
                
                const data = await response.json();
                
                if (data.success) {
                    showToast('Candidate scoring completed successfully!', 'success');
                    setTimeout(() => location.reload(), 2000);
                } else {
                    throw new Error(data.error || 'Scoring failed');
                }
                
            } catch (error) {
                loadingToast.hide();
                showToast(`Scoring failed: ${error.message}`, 'error');
                console.error('Scoring error:', error);
            }
        }

        // Run detailed role analysis using the backend API
        async function runDetailedRoleAnalysis(profileId) {
            if (!confirm('Run detailed role compatibility analysis? This will check compatibility for all executive roles (CIO, CTO, CISO).')) return;
            
            const loadingToast = showToast('Running detailed role analysis... This may take 10-30 seconds.', 'info', 0);
            const resultsContainer = document.getElementById('detailed-compatibility-results');
            
            try {
                const apiBaseUrl = '<%= res.locals.apiBaseUrl %>';
                const response = await fetch(`${apiBaseUrl}/api/v1/profiles/${profileId}/role-compatibility`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-API-Key': '<%= process.env.API_KEY || "" %>'
                    },
                    body: JSON.stringify({
                        target_roles: ['CIO', 'CTO', 'CISO'],
                        fast_screening: true
                    })
                });
                
                loadingToast.hide();
                
                if (!response.ok) {
                    const errorData = await response.json().catch(() => ({}));
                    throw new Error(errorData.message || `Server error: ${response.status}`);
                }
                
                const data = await response.json();
                
                if (data.compatible_roles) {
                    displayCompatibilityResults(data);
                    showToast('Role compatibility analysis completed!', 'success');
                } else {
                    throw new Error('Invalid response format from API');
                }
                
            } catch (error) {
                loadingToast.hide();
                showToast(`Role analysis failed: ${error.message}`, 'error');
                console.error('Role analysis error:', error);
            }
        }

        // Display detailed compatibility results
        function displayCompatibilityResults(data) {
            const container = document.getElementById('detailed-compatibility-results');
            if (!container) return;
            
            const html = `
                <div class="card border-0 bg-light">
                    <div class="card-header bg-transparent">
                        <h6 class="mb-0">Detailed Role Compatibility Results</h6>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Role</th>
                                        <th>Compatible</th>
                                        <th>Confidence</th>
                                        <th>Reasoning</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${data.compatible_roles.map(role => `
                                        <tr>
                                            <td>
                                                <strong>${role.role}</strong>
                                                ${role.role === data.recommended_primary_role ? 
                                                    '<i class="bi bi-star-fill text-warning ms-1" title="Recommended"></i>' : 
                                                    ''}
                                            </td>
                                            <td>
                                                <span class="badge bg-${role.compatible ? 'success' : 'danger'}">
                                                    <i class="bi bi-${role.compatible ? 'check' : 'x'}"></i>
                                                    ${role.compatible ? 'Yes' : 'No'}
                                                </span>
                                            </td>
                                            <td>${Math.round(role.confidence * 100)}%</td>
                                            <td class="small">${role.reasoning || 'No reasoning provided'}</td>
                                        </tr>
                                    `).join('')}
                                </tbody>
                            </table>
                        </div>
                        
                        ${data.overall_assessment ? `
                            <div class="mt-3">
                                <strong>Overall Assessment:</strong>
                                <p class="text-muted mb-0">${data.overall_assessment}</p>
                            </div>
                        ` : ''}
                        
                        <div class="mt-3">
                            <small class="text-muted">
                                <i class="bi bi-clock"></i> Analysis completed in ${data.ai_response_time?.toFixed(1) || 'N/A'}s using ${data.model_used || 'AI'}
                                <br>
                                ${data.proceed_with_scoring ? 
                                    '<i class="bi bi-check-circle text-success"></i> Candidate passed compatibility screening and can proceed to detailed scoring' :
                                    '<i class="bi bi-x-circle text-danger"></i> Candidate did not pass compatibility screening'
                                }
                            </small>
                        </div>
                    </div>
                </div>
            `;
            
            container.innerHTML = html;
            container.style.display = 'block';
        }
    </script>

    <style>
        .processing-steps .step {
            display: flex;
            align-items: center;
            margin-bottom: 0.75rem;
            font-size: 0.9rem;
        }

        .processing-steps .step i {
            margin-right: 0.75rem;
            font-size: 1.1rem;
        }

        .processing-steps .step.completed {
            color: var(--bs-success);
        }

        .processing-steps .step.pending {
            color: var(--bs-secondary);
        }

        .timeline-item {
            display: flex;
            margin-bottom: 1.5rem;
        }

        .timeline-marker {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            margin-right: 1rem;
            margin-top: 0.25rem;
            flex-shrink: 0;
        }

        .timeline-content {
            flex: 1;
            padding-bottom: 1rem;
            border-left: 2px solid #dee2e6;
            padding-left: 1rem;
            margin-left: -1.5rem;
        }

        .timeline-item:last-child .timeline-content {
            border-left: none;
        }

        /* Progress Modal Styles */
        .progress-steps {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .progress-step {
            display: flex;
            align-items: center;
            padding: 1rem;
            border-radius: 8px;
            background: #f8f9fa;
            border: 1px solid #e9ecef;
            transition: all 0.3s ease;
        }

        .progress-step.active {
            background: #e3f2fd;
            border-color: #2196f3;
        }

        .progress-step.completed {
            background: #e8f5e8;
            border-color: #4caf50;
        }

        .progress-step.error {
            background: #ffebee;
            border-color: #f44336;
        }

        .step-icon {
            width: 24px;
            height: 24px;
            margin-right: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .step-content {
            flex: 1;
        }

        .step-title {
            font-weight: 500;
            margin-bottom: 0.25rem;
        }

        .step-description {
            font-size: 0.875rem;
            margin: 0;
        }

        /* Toast Animations */
        .toast {
            opacity: 0;
            transform: translateX(100%);
        }

        .toast.show {
            opacity: 1;
            transform: translateX(0);
        }
    </style>
</body>
</html>
