<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - LinkedIn Ingestion Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/app.css" rel="stylesheet">
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="sidebar-wrapper px-0">
                <%- include('../partials/sidebar') %>
            </div>
            
            <!-- Main Content -->
            <div class="main-content">
                <%- include('../partials/header', { pageTitle: title }) %>
                
                <div class="container-fluid py-4">
                    <!-- Page Header -->
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div>
                            <h2 class="fw-bold mb-1">Job Scheduler</h2>
                            <p class="text-muted mb-0">
                                Automated candidate processing jobs and scheduling
                            </p>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-primary" onclick="refreshDashboard()">
                                <i class="bi bi-arrow-clockwise"></i> Refresh
                            </button>
                        </div>
                    </div>

                    <!-- Summary Stats -->
                    <div class="row mb-4">
                        <div class="col-xl-2 col-md-4 col-6">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-shrink-0">
                                            <div class="bg-primary bg-opacity-10 rounded-circle p-3">
                                                <i class="bi bi-gear-fill text-primary"></i>
                                            </div>
                                        </div>
                                        <div class="flex-grow-1 ms-3">
                                            <div class="fw-bold fs-4"><%= stats.totalJobs %></div>
                                            <div class="text-muted small">Total Jobs</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-2 col-md-4 col-6">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-shrink-0">
                                            <div class="bg-success bg-opacity-10 rounded-circle p-3">
                                                <i class="bi bi-play-fill text-success"></i>
                                            </div>
                                        </div>
                                        <div class="flex-grow-1 ms-3">
                                            <div class="fw-bold fs-4"><%= stats.enabledJobs %></div>
                                            <div class="text-muted small">Enabled</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-2 col-md-4 col-6">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-shrink-0">
                                            <div class="bg-warning bg-opacity-10 rounded-circle p-3">
                                                <i class="bi bi-hourglass text-warning"></i>
                                            </div>
                                        </div>
                                        <div class="flex-grow-1 ms-3">
                                            <div class="fw-bold fs-4"><%= stats.runningJobs %></div>
                                            <div class="text-muted small">Running</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-2 col-md-4 col-6">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-shrink-0">
                                            <div class="bg-info bg-opacity-10 rounded-circle p-3">
                                                <i class="bi bi-check-circle-fill text-info"></i>
                                            </div>
                                        </div>
                                        <div class="flex-grow-1 ms-3">
                                            <div class="fw-bold fs-4"><%= stats.recentSuccessful %></div>
                                            <div class="text-muted small">Success (24h)</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-2 col-md-4 col-6">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-shrink-0">
                                            <div class="bg-danger bg-opacity-10 rounded-circle p-3">
                                                <i class="bi bi-x-circle-fill text-danger"></i>
                                            </div>
                                        </div>
                                        <div class="flex-grow-1 ms-3">
                                            <div class="fw-bold fs-4"><%= stats.recentFailed %></div>
                                            <div class="text-muted small">Failed (24h)</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-2 col-md-4 col-6">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-shrink-0">
                                            <div class="bg-secondary bg-opacity-10 rounded-circle p-3">
                                                <i class="bi bi-activity text-secondary"></i>
                                            </div>
                                        </div>
                                        <div class="flex-grow-1 ms-3">
                                            <div class="fw-bold fs-4"><%= stats.recentTotal %></div>
                                            <div class="text-muted small">Total (24h)</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Jobs List -->
                    <div class="row">
                        <div class="col-lg-8">
                            <div class="card shadow-sm">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">
                                        <i class="bi bi-list-task me-2"></i>Scheduled Jobs
                                    </h5>
                                </div>
                                <div class="card-body p-0">
                                    <% if (jobs && jobs.length > 0) { %>
                                        <div class="table-responsive">
                                            <table class="table table-hover mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Job Name</th>
                                                        <th>Status</th>
                                                        <th>Last Run</th>
                                                        <th>Next Run</th>
                                                        <th>Success Rate</th>
                                                        <th>Actions</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% jobs.forEach(job => { %>
                                                        <tr>
                                                            <td>
                                                                <div class="d-flex align-items-center">
                                                                    <div class="status-indicator me-2">
                                                                        <% if (job.enabled) { %>
                                                                            <i class="bi bi-circle-fill text-success" title="Enabled"></i>
                                                                        <% } else { %>
                                                                            <i class="bi bi-circle text-muted" title="Disabled"></i>
                                                                        <% } %>
                                                                    </div>
                                                                    <div class="flex-grow-1">
                                                                        <div>
                                                                            <a href="/jobs/<%= job.name %>" class="fw-medium text-decoration-none">
                                                                                <%= job.displayName || job.name %>
                                                                            </a>
                                                                        </div>
                                                                        <% if (job.description) { %>
                                                                            <div class="small text-muted mt-1">
                                                                                <%= job.description %>
                                                                            </div>
                                                                        <% } %>
                                                                        <% if (job.tags && job.tags.length > 0) { %>
                                                                            <div class="mt-1">
                                                                                <% job.tags.forEach(tag => { %>
                                                                                    <span class="badge badge-sm bg-light text-dark me-1"><%= tag %></span>
                                                                                <% }); %>
                                                                            </div>
                                                                        <% } %>
                                                                    </div>
                                                                </div>
                                                            </td>
                                                            <td>
                                                                <% 
                                                                let statusClass = 'secondary';
                                                                let statusIcon = 'circle';
                                                                let statusText = job.status || 'idle';
                                                                
                                                                if (job.status === 'running') {
                                                                    statusClass = 'warning';
                                                                    statusIcon = 'hourglass';
                                                                } else if (job.status === 'completed') {
                                                                    statusClass = 'success';
                                                                    statusIcon = 'check-circle';
                                                                } else if (job.status === 'failed') {
                                                                    statusClass = 'danger';
                                                                    statusIcon = 'x-circle';
                                                                }
                                                                %>
                                                                <span class="badge bg-<%= statusClass %>">
                                                                    <i class="bi bi-<%= statusIcon %> me-1"></i>
                                                                    <%= statusText %>
                                                                </span>
                                                            </td>
                                                            <td>
                                                                <% if (job.lastRun) { %>
                                                                    <small class="text-muted">
                                                                        <%= new Date(job.lastRun).toLocaleDateString() %>
                                                                        <%= new Date(job.lastRun).toLocaleTimeString() %>
                                                                    </small>
                                                                <% } else { %>
                                                                    <span class="text-muted">Never</span>
                                                                <% } %>
                                                            </td>
                                                            <td>
                                                                <% if (job.nextRun && job.enabled) { %>
                                                                    <small class="text-muted">
                                                                        <%= new Date(job.nextRun).toLocaleDateString() %>
                                                                        <%= new Date(job.nextRun).toLocaleTimeString() %>
                                                                    </small>
                                                                <% } else { %>
                                                                    <span class="text-muted">—</span>
                                                                <% } %>
                                                            </td>
                                                            <td>
                                                                <% 
                                                                let successRate = 0;
                                                                if (job.runCount > 0) {
                                                                    successRate = Math.round(((job.runCount - job.failCount) / job.runCount) * 100);
                                                                }
                                                                %>
                                                                <% if (job.runCount > 0) { %>
                                                                    <span class="badge bg-<%= successRate >= 90 ? 'success' : successRate >= 70 ? 'warning' : 'danger' %>">
                                                                        <%= successRate %>%
                                                                    </span>
                                                                <% } else { %>
                                                                    <span class="text-muted">—</span>
                                                                <% } %>
                                                            </td>
                                                            <td>
                                                                <div class="btn-group" role="group">
                                                                    <button class="btn btn-sm btn-outline-primary" 
                                                                            onclick="triggerJob('<%= job.name %>')"
                                                                            title="Trigger Now">
                                                                        <i class="bi bi-play"></i>
                                                                    </button>
                                                                    <% if (job.enabled) { %>
                                                                        <button class="btn btn-sm btn-outline-warning" 
                                                                                onclick="stopJob('<%= job.name %>')"
                                                                                title="Stop Job">
                                                                            <i class="bi bi-pause"></i>
                                                                        </button>
                                                                    <% } else { %>
                                                                        <button class="btn btn-sm btn-outline-success" 
                                                                                onclick="startJob('<%= job.name %>')"
                                                                                title="Start Job">
                                                                            <i class="bi bi-play-fill"></i>
                                                                        </button>
                                                                    <% } %>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    <% }); %>
                                                </tbody>
                                            </table>
                                        </div>
                                    <% } else { %>
                                        <div class="text-center py-5 text-muted">
                                            <i class="bi bi-gear" style="font-size: 3rem;"></i>
                                            <p class="mt-2">No scheduled jobs found</p>
                                            <p class="small">Jobs will appear here once they are configured</p>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-lg-4">
                            <div class="card shadow-sm">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">
                                        <i class="bi bi-clock-history me-2"></i>Recent Activity
                                    </h5>
                                </div>
                                <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                                    <% if (recentHistory && recentHistory.length > 0) { %>
                                        <% recentHistory.slice(0, 10).forEach(run => { %>
                                            <div class="d-flex align-items-start mb-3">
                                                <div class="flex-shrink-0">
                                                    <% if (run.success) { %>
                                                        <i class="bi bi-check-circle-fill text-success"></i>
                                                    <% } else { %>
                                                        <i class="bi bi-x-circle-fill text-danger"></i>
                                                    <% } %>
                                                </div>
                                                <div class="flex-grow-1 ms-2">
                                                    <div class="fw-medium"><%= run.jobName %></div>
                                                    <div class="small text-muted">
                                                        <%= new Date(run.startTime).toLocaleString() %>
                                                        • Duration: <%= Math.round(run.duration / 1000) %>s
                                                    </div>
                                                    <% if (!run.success && run.error) { %>
                                                        <div class="small text-danger">
                                                            <%= run.error %>
                                                        </div>
                                                    <% } %>
                                                </div>
                                            </div>
                                        <% }); %>
                                    <% } else { %>
                                        <div class="text-center py-3 text-muted">
                                            <i class="bi bi-clock-history" style="font-size: 2rem;"></i>
                                            <p class="mt-2 mb-0">No recent activity</p>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" id="toast-container">
        <!-- Toasts will be dynamically added here -->
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Auto-refresh dashboard every 30 seconds
        setInterval(refreshDashboard, 30000);

        // Toast notification system
        function showToast(message, type = 'info', duration = 5000) {
            const toastContainer = document.getElementById('toast-container');
            const toastId = 'toast-' + Date.now();
            
            const iconMap = {
                'success': 'bi-check-circle-fill',
                'error': 'bi-x-circle-fill',
                'warning': 'bi-exclamation-triangle-fill',
                'info': 'bi-info-circle-fill'
            };
            
            const toast = document.createElement('div');
            toast.id = toastId;
            toast.className = `toast align-items-center text-bg-${type} border-0`;
            toast.setAttribute('role', 'alert');
            toast.innerHTML = `
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="bi ${iconMap[type]} me-2"></i>
                        ${message}
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            `;
            
            toastContainer.appendChild(toast);
            
            const bsToast = new bootstrap.Toast(toast, {
                autohide: duration > 0,
                delay: duration
            });
            
            bsToast.show();
            
            toast.addEventListener('hidden.bs.toast', function() {
                toast.remove();
            });
        }

        // Refresh dashboard
        function refreshDashboard() {
            location.reload();
        }

        // Trigger job manually
        async function triggerJob(jobName) {
            try {
                const response = await fetch(`/jobs/api/${jobName}/trigger`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                const data = await response.json();
                
                if (data.success) {
                    showToast(`Job "${jobName}" triggered successfully`, 'success');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    throw new Error(data.error);
                }
            } catch (error) {
                showToast(`Failed to trigger job: ${error.message}`, 'error');
            }
        }

        // Start job
        async function startJob(jobName) {
            try {
                const response = await fetch(`/jobs/api/${jobName}/start`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                const data = await response.json();
                
                if (data.success) {
                    showToast(`Job "${jobName}" started successfully`, 'success');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    throw new Error(data.error);
                }
            } catch (error) {
                showToast(`Failed to start job: ${error.message}`, 'error');
            }
        }

        // Stop job
        async function stopJob(jobName) {
            try {
                const response = await fetch(`/jobs/api/${jobName}/stop`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                const data = await response.json();
                
                if (data.success) {
                    showToast(`Job "${jobName}" stopped successfully`, 'warning');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    throw new Error(data.error);
                }
            } catch (error) {
                showToast(`Failed to stop job: ${error.message}`, 'error');
            }
        }
    </script>
</body>
</html>
