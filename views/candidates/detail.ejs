                    </div>
                    
                    <!-- Progress Bar -->
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted">Overall Progress</span>
                            <span class="text-muted" id="progressPercent">0%</span>
                        </div>
                        <div class="progress">
                            <div class="progress-bar" role="progressbar" id="progressBar" style="width: 0%"></div>
                        </div>
                    </div>
                    
                    <!-- Real-time Log -->
                    <div class="card">
                        <div class="card-header py-2">
                            <small class="text-muted">
                                <i class="bi bi-activity me-1"></i>Real-time Log
                            </small>
                        </div>
                        <div class="card-body p-2" style="max-height: 200px; overflow-y: auto;">
                            <div id="processingLog" class="font-monospace small text-muted">
                                Waiting to start processing...
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" id="startProcessingBtn">
                        <i class="bi bi-play-circle me-2"></i>Start Processing
                    </button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" id="cancelBtn">Cancel</button>
                </div>
            </div>
        </div>
    </div>

    <style>
        .processing-steps .step {
            display: flex;
            align-items: flex-start;
            padding: 12px 0;
            border-left: 2px solid #e9ecef;
            margin-left: 12px;
            position: relative;
        }
        
        .processing-steps .step:last-child {
            border-left: none;
        }
        
        .step-icon {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: #f8f9fa;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-left: -13px;
            margin-right: 12px;
            position: relative;
            z-index: 1;
        }
        
        .step.pending .step-icon {
            background: #f8f9fa;
            color: #6c757d;
        }
        
        .step.in-progress .step-icon {
            background: #0d6efd;
            color: white;
        }
        
        .step.in-progress .step-icon i::before {
            content: "\f1ce"; /* bi-gear-fill */
            animation: spin 2s linear infinite;
        }
        
        .step.completed .step-icon {
            background: #198754;
            color: white;
        }
        
        .step.completed .step-icon i::before {
            content: "\f26a"; /* bi-check-circle-fill */
        }
        
        .step.failed .step-icon {
            background: #dc3545;
            color: white;
        }
        
        .step.failed .step-icon i::before {
            content: "\f659"; /* bi-x-circle-fill */
        }
        
        .step-content {
            flex: 1;
        }
        
        .step-title {
            font-weight: 500;
            margin-bottom: 2px;
        }
        
        .step-description {
            color: #6c757d;
            font-size: 0.9em;
            margin-bottom: 4px;
        }
        
        .step-status {
            font-size: 0.85em;
            font-weight: 500;
        }
        
        .step.in-progress .step-status {
            color: #0d6efd;
        }
        
        .step.completed .step-status {
            color: #198754;
        }
        
        .step.failed .step-status {
            color: #dc3545;
        }
        
        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        
        #processingLog {
            /* Remove monospace styling for structured HTML display */
            font-family: inherit;
            line-height: 1.4;
        }
        
        /* Enhanced log entry styling */
        .log-entry {
            border-left: 3px solid transparent;
            padding-left: 8px;
            margin-bottom: 8px;
        }
        
        .log-entry[data-type="success"] {
            border-left-color: #28a745;
        }
        
        .log-entry[data-type="error"] {
            border-left-color: #dc3545;
        }
        
        .log-entry[data-type="warning"] {
            border-left-color: #ffc107;
        }
        
        .log-entry[data-type="info"] {
            border-left-color: #17a2b8;
        }
        
        .log-entry[data-type="progress"] {
            border-left-color: #007bff;
        }
        
        /* Timestamp styling */
        .log-timestamp {
            font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, Courier, monospace;
            font-size: 0.75rem;
            opacity: 0.7;
        }
        
        /* Icon styling */
        .log-icon {
            font-size: 0.9rem;
            line-height: 1;
            margin-top: 1px;
        }
        
        /* Message content styling */
        .log-message {
            font-weight: 500;
            line-height: 1.3;
        }
        
        .log-details {
            font-size: 0.8rem;
            line-height: 1.3;
        }
        
        .log-details .ps-3 {
            position: relative;
        }
        
        .log-details .ps-3::before {
            content: "→";
            position: absolute;
            left: 8px;
            opacity: 0.5;
        }
        
        /* Progress info styling */
        .progress-info .progress {
            border-radius: 2px;
            background-color: #f8f9fa;
        }
        
        .progress-info .progress-bar {
            border-radius: 2px;
            background: linear-gradient(45deg, #007bff 25%, transparent 25%), 
                        linear-gradient(-45deg, #007bff 25%, transparent 25%), 
                        linear-gradient(45deg, transparent 75%, #007bff 75%), 
                        linear-gradient(-45deg, transparent 75%, #007bff 75%);
            background-size: 8px 8px;
            animation: progress-stripe 1s linear infinite;
        }
        
        @keyframes progress-stripe {
            0% { background-position: 0 0; }
            100% { background-position: 8px 0; }
        }
        
        /* Responsive adjustments */
        @media (max-width: 768px) {
            .log-timestamp {
                min-width: 50px !important;
                font-size: 0.7rem;
            }
            
            .log-message {
                font-size: 0.85rem;
            }
            
            .log-details {
                font-size: 0.75rem;
            }
            
            .log-details .ps-3 {
                padding-left: 1rem !important;
            }
        }
        
        /* Hover effects for interactive elements */
        details summary {
            cursor: pointer;
            user-select: none;
        }
        
        details summary:hover {
            background-color: #f8f9fa;
            padding: 2px 4px;
            border-radius: 3px;
        }
        
        /* JSON formatting */
        details pre {
            max-height: 200px;
            overflow-y: auto;
            font-size: 0.7rem;
            margin-bottom: 0;
        }
        
        /* Animation for log entries */
        .log-entry {
            transition: opacity 0.3s ease, transform 0.3s ease;
        }
    </style>
</body>
</html>
