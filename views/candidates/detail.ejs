<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - LinkedIn Ingestion Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/app.css" rel="stylesheet">
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="sidebar-wrapper px-0">
                <%- include('../partials/sidebar') %>
            </div>
            
            <!-- Main Content -->
            <div class="main-content">
                <%- include('../partials/header', { pageTitle: title }) %>
                
                <div class="container-fluid py-4">
                    <!-- Breadcrumb -->
                    <nav aria-label="breadcrumb" class="mb-4">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Home</a></li>
                            <li class="breadcrumb-item"><a href="/candidates" class="text-decoration-none">Candidates</a></li>
                            <li class="breadcrumb-item active" aria-current="page"><%= candidate.key %></li>
                        </ol>
                    </nav>

                    <!-- Page Header -->
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div>
                            <h2 class="fw-bold mb-1">
                                <%= candidate.fullName || 'Unknown Candidate' %>
                                <span class="badge bg-primary ms-2"><%= candidate.key %></span>
                            </h2>
                            <p class="text-muted mb-0">
                                <% if (candidate.email) { %>
                                    <i class="bi bi-envelope me-1"></i> <%= candidate.email %>
                                <% } %>
                                <% if (candidate.phone) { %>
                                    <i class="bi bi-telephone ms-3 me-1"></i> <%= candidate.phone %>
                                <% } %>
                                <% if (candidate.region) { %>
                                    <i class="bi bi-geo-alt ms-3 me-1"></i> <%= candidate.region %>
                                <% } %>
                            </p>
                        </div>
                        <div class="d-flex gap-2">
                            <% if (candidate.linkedinUrl) { %>
                                <a href="<%= candidate.linkedinUrl %>" target="_blank" class="btn btn-outline-primary">
                                    <i class="bi bi-linkedin"></i> View LinkedIn
                                </a>
                                <button class="btn btn-success" onclick="processCandidate('<%= candidate.key %>', true)">
                                    <i class="bi bi-play-circle"></i> Process Candidate
                                </button>
                            <% } %>
                        </div>
                    </div>

                    <div class="row">
                        <!-- Left Column - Candidate Info -->
                        <div class="col-lg-8">
                            <!-- Basic Information Card -->
                            <div class="card shadow-sm mb-4">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">
                                        <i class="bi bi-person-circle me-2"></i>Basic Information
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label fw-medium">Full Name</label>
                                            <div class="form-control-plaintext"><%= candidate.fullName || 'Not specified' %></div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-medium">Email</label>
                                            <div class="form-control-plaintext">
                                                <% if (candidate.email) { %>
                                                    <a href="mailto:<%= candidate.email %>" class="text-decoration-none">
                                                        <%= candidate.email %>
                                                    </a>
                                                <% } else { %>
                                                    Not specified
                                                <% } %>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-medium">Phone</label>
                                            <div class="form-control-plaintext">
                                                <% if (candidate.phone) { %>
                                                    <a href="tel:<%= candidate.phone %>" class="text-decoration-none">
                                                        <%= candidate.phone %>
                                                    </a>
                                                <% } else { %>
                                                    Not specified
                                                <% } %>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-medium">Region</label>
                                            <div class="form-control-plaintext"><%= candidate.region || 'Not specified' %></div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-medium">LinkedIn Profile</label>
                                            <div class="form-control-plaintext">
                                                <% if (candidate.linkedinUrl) { %>
                                                    <a href="<%= candidate.linkedinUrl %>" target="_blank" class="text-decoration-none">
                                                        <i class="bi bi-linkedin text-primary"></i> View Profile
                                                    </a>
                                                <% } else { %>
                                                    Not available
                                                <% } %>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-medium">Created Date</label>
                                            <div class="form-control-plaintext">
                                                <% if (candidate.created) { %>
                                                    <%= new Date(candidate.created).toLocaleDateString('en-US', { 
                                                        year: 'numeric', 
                                                        month: 'long', 
                                                        day: 'numeric' 
                                                    }) %>
                                                <% } else { %>
                                                    Unknown
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Profile Data Card -->
                            <% if (profileData) { %>
                                <div class="card shadow-sm mb-4">
                                    <div class="card-header">
                                        <h5 class="card-title mb-0">
                                            <i class="bi bi-database me-2"></i>Profile Data
                                        </h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label class="form-label fw-medium">Profile ID</label>
                                                <div class="form-control-plaintext">
                                                    <code><%= profileData.id %></code>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label fw-medium">Current Score</label>
                                                <div class="form-control-plaintext">
                                                    <% if (profileData.score !== null && profileData.score !== undefined) { %>
                                                        <span class="badge bg-success fs-6">
                                                            <i class="bi bi-star-fill"></i> <%= profileData.score %>
                                                        </span>
                                                    <% } else { %>
                                                        <span class="text-muted">Not scored yet</span>
                                                    <% } %>
                                                    <div class="mt-1">
                                                        <% if (profileData && profileData.score !== null && profileData.score !== undefined) { %>
                                                            <small class="text-muted">
                                                                Last scored: <%= profileData.updated_at ? new Date(profileData.updated_at).toLocaleString() : 'Unknown' %>
                                                            </small>
                                                        <% } %>
                                                    </div>
                                                </div>
                                            </div>
                            <div class="col-12">
                                <label class="form-label fw-medium">Role Assessment</label>
                                <div class="form-control-plaintext">
                                    <% if (profileData && profileData.suggested_role) { %>
                                        <!-- Suggested Role Display -->
                                        <div class="role-assessment">
                                            <div class="row align-items-center">
                                                <div class="col-md-6">
                                                    <div class="d-flex align-items-center">
                                                        <span class="badge bg-primary fs-5 me-3">
                                                            <i class="bi bi-person-badge"></i> <%= profileData.suggested_role %>
                                                        </span>
                                                        <div>
                                                            <div class="fw-medium">Suggested Role</div>
                                                            <div class="small text-muted">Based on profile analysis</div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <button class="btn btn-outline-info btn-sm" onclick="runDetailedRoleAnalysis('<%= profileData.id %>')">
                                                        <i class="bi bi-graph-up"></i> Run Detailed Analysis
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <!-- Container for detailed results (populated by AJAX) -->
                                        <div id="detailed-compatibility-results" class="mt-3" style="display: none;"></div>
                                        
                                    <% } else { %>
                                        <span class="badge bg-warning fs-6">
                                            <i class="bi bi-question-circle"></i> Not Assessed
                                        </span>
                                        <div class="small text-muted mt-1">
                                            Role assessment not available. Profile may need to be processed.
                                            <% if (profileData && profileData.id) { %>
                                                <button class="btn btn-link btn-sm p-0 ms-2" onclick="runDetailedRoleAnalysis('<%= profileData.id %>')">
                                                    Run Analysis
                                                </button>
                                            <% } %>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                            
                            <!-- Detailed Scoring Results Section -->
                            <% if (profileData && profileData.score !== null && profileData.score !== undefined) { %>
                                <div class="col-12">
                                    <label class="form-label fw-medium">Detailed Scoring Results</label>
                                    <div class="form-control-plaintext">
                                        <div class="scoring-results">
                                            <!-- Overall Score Display -->
                                            <div class="row mb-4">
                                                <div class="col-md-6">
                                                    <div class="card bg-success text-white">
                                                        <div class="card-body text-center">
                                                            <h2 class="display-4 fw-bold mb-0">
                                                                <%= profileData.score %>
                                                                <small class="fs-6">/10</small>
                                                            </h2>
                                                            <p class="mb-0">Overall Score</p>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <div class="card bg-primary text-white">
                                                        <div class="card-body text-center">
                                                            <h4 class="fw-bold mb-1">
                                                                <i class="bi bi-award me-2"></i><%= profileData.suggested_role || 'Unknown' %>
                                                            </h4>
                                                            <p class="mb-0">Suggested Role</p>
                                                            <% if (profileData.scoring_job_id) { %>
                                                                <small class="opacity-75">
                                                                    Job: <%= profileData.scoring_job_id.substring(0, 8) %>...
                                                                </small>
                                                            <% } %>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            
                                            <!-- Scoring Breakdown -->
                                            <% if (profileData.scoring_breakdown) { %>
                                                <div class="scoring-breakdown">
                                                    <h6 class="fw-bold mb-3">Scoring Breakdown</h6>
                                                    <% 
                                                    const scoringData = typeof profileData.scoring_breakdown === 'string' 
                                                        ? JSON.parse(profileData.scoring_breakdown) 
                                                        : profileData.scoring_breakdown;
                                                    %>
                                                    
                                                    <% if (scoringData.criteria && Array.isArray(scoringData.criteria)) { %>
                                                        <div class="row g-3">
                                                            <% scoringData.criteria.forEach((criterion, index) => { %>
                                                                <div class="col-md-6">
                                                                    <div class="card border-0 bg-light">
                                                                        <div class="card-body py-3">
                                                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                                                <h6 class="mb-0"><%= criterion.name || `Criterion ${index + 1}` %></h6>
                                                                                <span class="badge bg-<%= criterion.score >= 8 ? 'success' : criterion.score >= 6 ? 'warning' : 'danger' %> fs-6">
                                                                                    <%= criterion.score %>/10
                                                                                </span>
                                                                            </div>
                                                                            <% if (criterion.comments) { %>
                                                                                <p class="small text-muted mb-0"><%= criterion.comments %></p>
                                                                            <% } %>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            <% }); %>
                                                        </div>
                                                    <% } %>
                                                    
                                                    <!-- Overall Comments -->
                                                    <% if (scoringData.overall_comments) { %>
                                                        <div class="mt-4">
                                                            <h6 class="fw-bold mb-2">Overall Assessment</h6>
                                                            <div class="card border-0 bg-light">
                                                                <div class="card-body">
                                                                    <p class="mb-0"><%= scoringData.overall_comments %></p>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    <% } %>
                                                </div>
                                            <% } %>
                                            
                                            <!-- Scoring Job Information -->
                                            <div class="mt-4 p-3 bg-light rounded">
                                                <div class="row align-items-center">
                                                    <div class="col-md-8">
                                                        <small class="text-muted">Scoring Details</small>
                                                        <div class="fw-medium">
                                                            <% if (profileData.scoring_job_id) { %>
                                                                Scored by AI using CTO role template
                                                            <% } else { %>
                                                                AI-generated score for CTO role
                                                            <% } %>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-4 text-end">
                                                        <% if (profileData.scoring_job_id) { %>
                                                            <a href="/scoring/jobs/<%= profileData.scoring_job_id %>" class="btn btn-outline-primary btn-sm">
                                                                <i class="bi bi-eye"></i> View Job Details
                                                            </a>
                                                        <% } %>
                                                    </div>
                                                </div>
                                                <% if (profileData.score_updated_at || profileData.updated_at) { %>
                                                    <div class="mt-2">
                                                        <small class="text-muted">
                                                            <i class="bi bi-clock"></i> 
                                                            Scored on <%= new Date(profileData.score_updated_at || profileData.updated_at).toLocaleDateString('en-US', { 
                                                                year: 'numeric', 
                                                                month: 'short', 
                                                                day: 'numeric',
                                                                hour: '2-digit',
                                                                minute: '2-digit'
                                                            }) %>
                                                        </small>
                                                    </div>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% } %>
                            
                            <!-- Role Compatibility Results Section -->
                            <% if (profileData && profileData.compatibilityData) { %>
                                <div class="col-12">
                                    <label class="form-label fw-medium">Role Compatibility Assessment</label>
                                    <div class="form-control-plaintext">
                                        <div class="compatibility-results">
                                            <!-- Overall Assessment -->
                                            <div class="row mb-3">
                                                <div class="col-md-8">
                                                    <div class="card bg-<%= profileData.compatibility_passed ? 'success' : 'warning' %> text-white">
                                                        <div class="card-body">
                                                            <div class="d-flex align-items-center">
                                                                <div class="me-3">
                                                                    <i class="bi bi-<%= profileData.compatibility_passed ? 'check-circle-fill' : 'exclamation-triangle-fill' %> fs-2"></i>
                                                                </div>
                                                                <div>
                                                                    <h5 class="mb-1">
                                                                        <%= profileData.compatibility_passed ? 'Compatible for Scoring' : 'Limited Compatibility' %>
                                                                    </h5>
                                                                    <p class="mb-0">
                                                                        Recommended Role: <strong><%= profileData.recommended_role %></strong>
                                                                    </p>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="text-center">
                                                        <div class="display-6 fw-bold mb-1">
                                                            <%= Math.round((profileData.compatibilityData.confidence_score || 0) * 100) %>%
                                                        </div>
                                                        <div class="text-muted">Confidence</div>
                                                    </div>
                                                </div>
                                            </div>
                                            
                                            <!-- Role Breakdown -->
                                            <% if (profileData.compatibilityData.compatible_roles && Array.isArray(profileData.compatibilityData.compatible_roles)) { %>
                                                <div class="compatibility-breakdown">
                                                    <h6 class="fw-bold mb-3">Role Analysis Breakdown</h6>
                                                    <div class="row g-3">
                                                        <% profileData.compatibilityData.compatible_roles.forEach((roleResult, index) => { %>
                                                            <div class="col-md-4">
                                                                <div class="card border-0 bg-light">
                                                                    <div class="card-body py-3">
                                                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                                                            <h6 class="mb-0">
                                                                                <%= roleResult.role %>
                                                                                <% if (roleResult.role === profileData.recommended_role) { %>
                                                                                    <i class="bi bi-star-fill text-warning ms-1" title="Recommended"></i>
                                                                                <% } %>
                                                                            </h6>
                                                                            <span class="badge bg-<%= roleResult.compatible ? 'success' : 'secondary' %>">
                                                                                <%= Math.round(roleResult.confidence * 100) %>%
                                                                            </span>
                                                                        </div>
                                                                        <div class="progress mb-2" style="height: 4px;">
                                                                            <div class="progress-bar bg-<%= roleResult.compatible ? 'success' : 'secondary' %>" 
                                                                                 style="width: <%= Math.round(roleResult.confidence * 100) %>%"></div>
                                                                        </div>
                                                                        <% if (roleResult.reasoning) { %>
                                                                            <p class="small text-muted mb-0"><%= roleResult.reasoning.substring(0, 100) %><%= roleResult.reasoning.length > 100 ? '...' : '' %></p>
                                                                        <% } %>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        <% }); %>
                                                    </div>
                                                </div>
                                            <% } %>
                                            
                                            <!-- Overall Assessment -->
                                            <% if (profileData.compatibilityData.overall_assessment) { %>
                                                <div class="mt-4">
                                                    <h6 class="fw-bold mb-2">Overall Assessment</h6>
                                                    <div class="card border-0 bg-light">
                                                        <div class="card-body">
                                                            <p class="mb-0"><%= profileData.compatibilityData.overall_assessment %></p>
                                                        </div>
                                                    </div>
                                                </div>
                                            <% } %>
                                            
                                            <!-- Analysis Metadata -->
                                            <div class="mt-4 p-3 bg-light rounded">
                                                <div class="row align-items-center">
                                                    <div class="col-md-8">
                                                        <small class="text-muted">Compatibility Analysis Details</small>
                                                        <div class="fw-medium">
                                                            AI-powered role assessment using <%= profileData.compatibilityData.model_used || 'OpenAI' %>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-4 text-end">
                                                        <% if (profileData.compatibilityData.ai_response_time) { %>
                                                            <small class="text-muted">
                                                                <i class="bi bi-clock"></i> 
                                                                <%= profileData.compatibilityData.ai_response_time.toFixed(1) %>s processing time
                                                            </small>
                                                        <% } %>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% } %>
                            
                                            <div class="col-md-6">
                                                <label class="form-label fw-medium">Profile Created</label>
                                                <div class="form-control-plaintext">
                                                    <%= new Date(profileData.created_at).toLocaleDateString('en-US', { 
                                                        year: 'numeric', 
                                                        month: 'short', 
                                                        day: 'numeric',
                                                        hour: '2-digit',
                                                        minute: '2-digit'
                                                    }) %>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% } %>

                            <!-- Latest Fit Score & Status Card -->
                            <% if (latestScoring || roleCompatibility) { %>
                                <div class="card shadow-sm mb-4">
                                    <div class="card-header">
                                        <h5 class="card-title mb-0">
                                            <i class="bi bi-trophy me-2"></i>Fit Assessment
                                        </h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row g-4">
                                            <!-- Fit Score -->
                                            <% if (latestScoring && latestScoring.parsed_score) { %>
                                                <div class="col-md-4">
                                                    <div class="text-center">
                                                        <div class="display-4 fw-bold mb-2">
                                                            <% 
                                                            const scoreData = typeof latestScoring.parsed_score === 'string' 
                                                                ? JSON.parse(latestScoring.parsed_score) 
                                                                : latestScoring.parsed_score;
                                                            const totalScore = scoreData.total_score || 0;
                                                            %>
                                                            <%= totalScore %>
                                                        </div>
                                                        <div class="text-muted">Fit Score</div>
                                                        <% if (scoreData.fit_verdict) { %>
                                                            <div class="badge bg-<%= scoreData.fit_verdict.includes('Elite') ? 'success' : scoreData.fit_verdict.includes('Strong') ? 'info' : scoreData.fit_verdict.includes('Good') ? 'primary' : 'warning' %> mt-2">
                                                                <%= scoreData.fit_verdict %>
                                                            </div>
                                                        <% } %>
                                                    </div>
                                                </div>
                                            <% } %>

                                            <!-- Fit Status -->
                                            <% if (roleCompatibility && roleCompatibility.compatible_roles) { %>
                                                <div class="col-md-8">
                                                    <h6 class="fw-bold mb-3">Role Compatibility</h6>
                                                    <% 
                                                    const compatData = typeof roleCompatibility.compatible_roles === 'string' 
                                                        ? JSON.parse(roleCompatibility.compatible_roles) 
                                                        : roleCompatibility.compatible_roles;
                                                    %>
                                                    <% if (compatData && Array.isArray(compatData)) { %>
                                                        <% compatData.forEach((role, index) => { %>
                                                            <div class="d-flex align-items-center mb-2">
                                                                <span class="badge bg-<%= role.compatible ? 'success' : 'warning' %> fs-6 me-3">
                                                                    <%= role.role %>
                                                                </span>
                                                                <div class="progress flex-fill me-3" style="height: 8px;">
                                                                    <div class="progress-bar bg-<%= role.compatible ? 'success' : 'warning' %>" 
                                                                         style="width: <%= (role.confidence * 100).toFixed(0) %>%"></div>
                                                                </div>
                                                                <small class="text-muted"><%= (role.confidence * 100).toFixed(0) %>% confidence</small>
                                                            </div>
                                                            <% if (role.reasoning) { %>
                                                                <p class="small text-muted mb-3"><strong><%= role.role %>:</strong> <%= role.reasoning %></p>
                                                            <% } %>
                                                        <% }); %>
                                                    <% } %>
                                                </div>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            <% } %>

                            <!-- Recent Comments Card -->
                            <% if (recentComments && recentComments.length > 0) { %>
                                <div class="card shadow-sm mb-4">
                                    <div class="card-header">
                                        <h5 class="card-title mb-0">
                                            <i class="bi bi-chat-dots me-2"></i>Recent Comments
                                        </h5>
                                    </div>
                                    <div class="card-body">
                                        <% recentComments.forEach((comment, index) => { %>
                                            <div class="comment-item <% if (index < recentComments.length - 1) { %>mb-3 pb-3 border-bottom<% } %>">
                                                <div class="d-flex justify-content-between align-items-start mb-2">
                                                    <div class="fw-medium"><%= comment.author.displayName %></div>
                                                    <small class="text-muted">
                                                        <%= new Date(comment.created).toLocaleDateString('en-US', { 
                                                            month: 'short', 
                                                            day: 'numeric',
                                                            hour: '2-digit',
                                                            minute: '2-digit'
                                                        }) %>
                                                    </small>
                                                </div>
                                                <div class="text-muted"><%= comment.body %></div>
                                            </div>
                                        <% }); %>
                                    </div>
                                </div>
                            <% } %>

                            <!-- Processing History -->
                            <div class="card shadow-sm mb-4">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">
                                        <i class="bi bi-clock-history me-2"></i>Processing History
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <% if (processingHistory && processingHistory.length > 0) { %>
                                        <div class="timeline">
                                            <% processingHistory.forEach((job, index) => { %>
                                                <div class="timeline-item">
                                                    <div class="timeline-marker bg-<%= job.status === 'completed' ? 'success' : job.status === 'failed' ? 'danger' : 'primary' %>"></div>
                                                    <div class="timeline-content">
                                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                                            <h6 class="mb-0"><%= job.type || 'Processing Job' %></h6>
                                                            <small class="text-muted">
                                                                <%= new Date(job.created_at).toLocaleDateString() %>
                                                            </small>
                                                        </div>
                                                        <div class="mb-2">
                                                            <span class="badge bg-<%= job.status === 'completed' ? 'success' : job.status === 'failed' ? 'danger' : 'primary' %>">
                                                                <%= job.status %>
                                                            </span>
                                                        </div>
                                                        <% if (job.result || job.error) { %>
                                                            <div class="small text-muted">
                                                                <%= job.result || job.error %>
                                                            </div>
                                                        <% } %>
                                                    </div>
                                                </div>
                                            <% }); %>
                                        </div>
                                    <% } else { %>
                                        <div class="text-center py-4">
                                            <div class="text-muted mb-2">
                                                <i class="bi bi-clock-history" style="font-size: 2rem; opacity: 0.3;"></i>
                                            </div>
                                            <p class="text-muted mb-0">No processing history available</p>
                                            <small class="text-muted">Processing steps will appear here once the candidate is processed</small>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>

                        <!-- Right Column - Status & Actions -->
                        <div class="col-lg-4">
                            <!-- Status Card -->
                            <div class="card shadow-sm mb-4">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">
                                        <i class="bi bi-info-circle me-2"></i>Status Information
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <label class="form-label fw-medium">Jira Status</label>
                                        <div>
                                            <span class="badge bg-<%= candidate.status === 'Open' ? 'primary' : candidate.status === 'In Progress' ? 'warning' : 'success' %> fs-6">
                                                <%= candidate.status || 'Unknown' %>
                                            </span>
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-medium">Standing</label>
                                        <div>
                                            <% if (candidate.standing) { %>
                                                <span class="badge bg-<%= candidate.standing.includes('Excellent') ? 'success' : candidate.standing.includes('Good') || candidate.standing.includes('Qualified') ? 'info' : 'secondary' %> fs-6">
                                                    <%= candidate.standing %>
                                                </span>
                                            <% } else { %>
                                                <span class="text-muted">Not set</span>
                                            <% } %>
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-medium">Assignee</label>
                                        <div class="form-control-plaintext">
                                            <%= candidate.assignee || 'Unassigned' %>
                                        </div>
                                    </div>
                                    <div class="mb-0">
                                        <label class="form-label fw-medium">Reporter</label>
                                        <div class="form-control-plaintext">
                                            <%= candidate.reporter || 'Unknown' %>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Processing Status Card -->
                            <div class="card shadow-sm mb-4">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">
                                        <i class="bi bi-gear me-2"></i>Processing Status
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="me-3">
                                            <% const statusBadge = candidate.statusBadge || {text: 'Unknown', class: 'badge-secondary', icon: 'bi bi-question'}; %>
                                            <span class="badge <%= statusBadge.class %> fs-6">
                                                <i class="<%= statusBadge.icon %> me-1"></i>
                                                <%= statusBadge.text %>
                                            </span>
                                        </div>
                                    </div>
                                    
                                    <!-- Processing Steps -->
                                    <div class="processing-steps">
                                        <div class="step <%= candidate.hasLinkedIn ? 'completed' : 'pending' %>">
                                            <div>
                                                <i class="bi bi-<%= candidate.hasLinkedIn ? 'check-circle-fill' : 'circle' %>"></i>
                                                <span>LinkedIn Profile Available</span>
                                                <% if (candidate.hasLinkedIn && candidate.linkedinVerifiedDate) { %>
                                                    <div class="small text-muted mt-1">
                                                        <i class="bi bi-clock me-1"></i>
                                                        Verified: <%= new Date(candidate.linkedinVerifiedDate).toLocaleString() %>
                                                    </div>
                                                <% } %>
                                            </div>
                                        </div>
                                        <div class="step <%= candidate.hasProfile ? 'completed' : 'pending' %>">
                                            <div>
                                                <i class="bi bi-<%= candidate.hasProfile ? 'check-circle-fill' : 'circle' %>"></i>
                                                <span>Profile Ingested</span>
                                                <% if (candidate.hasProfile && profileData && profileData.created_at) { %>
                                                    <div class="small text-muted mt-1">
                                                        <i class="bi bi-clock me-1"></i>
                                                        Ingested: <%= new Date(profileData.created_at).toLocaleString() %>
                                                    </div>
                                                <% } %>
                                            </div>
                                        </div>
                                        <div class="step <%= profileData && profileData.has_compatibility_data ? 'completed' : 'pending' %>" id="compatibility-step">
                                            <div>
                                                <i class="bi bi-<%= profileData && profileData.has_compatibility_data ? 'check-circle-fill' : 'circle' %>" id="compatibility-icon"></i>
                                                <span>Compatibility Checked</span>
                                                <% if (profileData && profileData.compatibilityData && profileData.recommended_role) { %>
                                                    <span class="badge bg-<%= profileData.compatibility_passed ? 'success' : 'warning' %> ms-2">
                                                        <%= profileData.recommended_role %>
                                                    </span>
                                                <% } %>
                                                <% if (profileData && profileData.has_compatibility_data && profileData.compatibility_checked_at) { %>
                                                    <div class="small text-muted mt-1">
                                                        <i class="bi bi-clock me-1"></i>
                                                        Checked: <%= new Date(profileData.compatibility_checked_at).toLocaleString() %>
                                                    </div>
                                                <% } %>
                                            </div>
                                        </div>
                                        <div class="step <%= profileData && profileData.score !== null && profileData.score !== undefined ? 'completed' : 'pending' %>">
                                            <div>
                                                <i class="bi bi-<%= profileData && profileData.score !== null && profileData.score !== undefined ? 'check-circle-fill' : 'circle' %>"></i>
                                                <span>Scored</span>
                                                <% if (profileData && profileData.score !== null && profileData.score !== undefined && profileData.scored_at) { %>
                                                    <div class="small text-muted mt-1">
                                                        <i class="bi bi-clock me-1"></i>
                                                        Scored: <%= new Date(profileData.scored_at).toLocaleString() %>
                                                    </div>
                                                <% } %>
                                            </div>
                                        </div>
                                        <div class="step <%= profileData && profileData.jira_updated ? 'completed' : 'pending' %>">
                                            <div>
                                                <i class="bi bi-<%= profileData && profileData.jira_updated ? 'check-circle-fill' : 'circle' %>"></i>
                                                <span>JIRA Updated</span>
                                                <% if (profileData && profileData.jira_updated && profileData.jira_updated_at) { %>
                                                    <div class="small text-muted mt-1">
                                                        <i class="bi bi-clock me-1"></i>
                                                        Updated: <%= new Date(profileData.jira_updated_at).toLocaleString() %>
                                                    </div>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="mt-3">
                                        <small class="text-muted">
                                            <i class="bi bi-clock me-1"></i>
                                            Last processing activity: 
                                            <%
                                            // Find the most recent activity timestamp
                                            let lastActivity = null;
                                            
                                            // Check profile updated_at
                                            if (profileData && profileData.updated_at) {
                                                lastActivity = new Date(profileData.updated_at);
                                            }
                                            
                                            // Check profile created_at if no updated_at
                                            if (!lastActivity && profileData && profileData.created_at) {
                                                lastActivity = new Date(profileData.created_at);
                                            }
                                            
                                            // Check latest scoring activity
                                            if (latestScoring && latestScoring.created_at) {
                                                const scoringDate = new Date(latestScoring.created_at);
                                                if (!lastActivity || scoringDate > lastActivity) {
                                                    lastActivity = scoringDate;
                                                }
                                            }
                                            
                                            // Check compatibility data timestamp (if available)
                                            if (roleCompatibility && roleCompatibility.created_at) {
                                                const compatDate = new Date(roleCompatibility.created_at);
                                                if (!lastActivity || compatDate > lastActivity) {
                                                    lastActivity = compatDate;
                                                }
                                            }
                                            %>
                                            <%= lastActivity ? lastActivity.toLocaleString() : 'No recent activity' %>
                                        </small>
                                    </div>
                                </div>
                            </div>

                            <!-- Actions Card -->
                            <div class="card shadow-sm">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">
                                        <i class="bi bi-lightning me-2"></i>Actions
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="d-grid gap-2">
                                        <% if (candidate.linkedinUrl) { %>
                                            <button class="btn btn-primary" 
                                                    onclick="processCandidate('<%= candidate.key %>', true)"
                                                    title="Run full processing pipeline: verify LinkedIn, ingest data, check role compatibility, and score"
                                                    data-bs-toggle="tooltip" 
                                                    data-bs-placement="top">
                                                <i class="bi bi-play-circle me-2"></i>Process All Steps
                                            </button>
                                            <button class="btn btn-outline-primary" 
                                                    onclick="ingestProfile('<%= candidate.key %>')"
                                                    title="Verify LinkedIn URL and ingest profile data only (no compatibility check or scoring)"
                                                    data-bs-toggle="tooltip" 
                                                    data-bs-placement="top">
                                                <i class="bi bi-download me-2"></i>Ingest Profile Only
                                            </button>
                                            <% if (profileData && profileData.has_compatibility_data && profileData.compatibility_passed) { %>
                                                <button class="btn btn-outline-success" 
                                                        onclick="scoreCandidate('<%= candidate.key %>')"
                                                        title="Score this candidate using AI evaluation templates"
                                                        data-bs-toggle="tooltip" 
                                                        data-bs-placement="top">
                                                    <i class="bi bi-star me-2"></i>Score Candidate
                                                </button>
                                            <% } %>
                                        <% } else { %>
                                            <div class="alert alert-warning mb-0">
                                                <i class="bi bi-exclamation-triangle me-2"></i>
                                                No LinkedIn profile available for processing.
                                            </div>
                                        <% } %>
                                        
                                        <hr>
                                        
                                        <a href="/candidates" class="btn btn-outline-secondary">
                                            <i class="bi bi-arrow-left me-2"></i>Back to Candidates
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <!-- Toast Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" id="toast-container">
        <!-- Toasts will be dynamically added here -->
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script>
        // Initialize Bootstrap tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });

        // Global variables
        let currentProcessingRequest;
        

        // Toast notification system
        function showToast(message, type = 'info', duration = 5000) {
            const toastContainer = document.getElementById('toast-container');
            const toastId = 'toast-' + Date.now();
            
            const iconMap = {
                'success': 'bi-check-circle-fill',
                'error': 'bi-x-circle-fill',
                'warning': 'bi-exclamation-triangle-fill',
                'info': 'bi-info-circle-fill'
            };
            
            const toast = document.createElement('div');
            toast.id = toastId;
            toast.className = `toast align-items-center text-bg-${type} border-0`;
            toast.setAttribute('role', 'alert');
            toast.innerHTML = `
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="bi ${iconMap[type]} me-2"></i>
                        ${message}
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            `;
            
            toastContainer.appendChild(toast);
            
            const bsToast = new bootstrap.Toast(toast, {
                autohide: duration > 0,
                delay: duration
            });
            
            bsToast.show();
            
            // Remove from DOM after hiding
            toast.addEventListener('hidden.bs.toast', function() {
                toast.remove();
            });
            
            return bsToast;
        }

        // =============================================================================
        // PROCESSING MODAL FUNCTIONALITY
        // =============================================================================
        
        let processingModal = null;
        let currentCandidateKey = null;
        let isProcessingActive = false;
        
        // Show the processing modal
        function showProcessingModal(candidateKey, allSteps = false) {
            currentCandidateKey = candidateKey;
            
            // Initialize WebSocket connection now that io is available
            initializeWebSocket();
            console.log('Opening processing modal for:', candidateKey);
            
            // Set up modal content
            document.getElementById('processingCandidateName').textContent = `${candidateKey} - <%= candidate.fullName || candidate.key %>`;
            document.getElementById('processingExecutionId').textContent = '';
            
            // Show/hide scoring step based on allSteps parameter
            const scoreStep = document.getElementById('step-score');
            if (allSteps) {
                scoreStep.style.display = 'flex';
            } else {
                scoreStep.style.display = 'none';
            }
            
            // Reset all steps to pending
            resetModalSteps();
            
            // Reset progress
            updateModalProgress(0);
            
            // Clear log and set initial message
            const log = document.getElementById('processingLog');
            log.innerHTML = '';
            addModalLogEntry('Ready to start processing...', 'info');
            
            // Set up event listeners
            document.getElementById('startProcessingBtn').onclick = () => startProcessingFromModal(candidateKey, allSteps);
            
            // Show modal
            processingModal = new bootstrap.Modal(document.getElementById('processingModal'), {
                backdrop: 'static',
                keyboard: false
            });
            processingModal.show();
        }
        
        // Reset all modal steps to pending
        function resetModalSteps() {
            const steps = ['verify', 'ingest', 'compatibility', 'score', 'update_jira'];
            steps.forEach(step => {
                const stepEl = document.getElementById(`step-${step}`);
                stepEl.className = 'step pending';
                stepEl.querySelector('.step-status').textContent = '';
            });
        }
        
        // Update modal progress
        function updateModalProgress(percent) {
            document.getElementById('progressBar').style.width = percent + '%';
            document.getElementById('progressPercent').textContent = Math.round(percent) + '%';
        }
        
        // Enhanced log entry formatting functions
        function formatLogEntryWithStructure(message, type = 'info', data = null, timestamp = null) {
            const now = timestamp || new Date();
            const timeString = now.toLocaleTimeString('en-US', { 
                hour12: false, 
                hour: '2-digit', 
                minute: '2-digit', 
                second: '2-digit' 
            });
            
            const typeIcons = {
                'info': 'ℹ️',
                'success': '✅',
                'warning': '⚠️',
                'error': '❌',
                'progress': '⏳'
            };
            
            const icon = typeIcons[type] || 'ℹ️';
            const formattedMessage = formatMessageContent(message, data);
            
            return {
                timestamp: timeString,
                icon,
                type,
                message: formattedMessage,
                data: data,
                html: generateLogEntryHTML(timeString, icon, type, formattedMessage, data)
            };
        }

        function formatMessageContent(message, data) {
            if (!data) return message;
            
            // Format different data types
            if (data.url) {
                return `${message}\n  → URL: ${truncateUrl(data.url)}`;
            }
            
            if (data.profile) {
                const profileDetails = [];
                if (data.profile.name) profileDetails.push(`Name: ${data.profile.name}`);
                if (data.profile.title) profileDetails.push(`Title: ${data.profile.title}`);
                if (data.profile.company) profileDetails.push(`Company: ${data.profile.company}`);
                
                if (profileDetails.length > 0) {
                    return `${message}\n  → ${profileDetails.join(', ')}`;
                }
            }
            
            if (data.scores && Array.isArray(data.scores)) {
                const scoreDetails = data.scores.map(score => 
                    `${score.role}: ${(score.confidence * 10).toFixed(1)}/10`
                ).join(', ');
                return `${message}\n  → ${scoreDetails}`;
            }
            
            if (data.jiraFields) {
                const fieldUpdates = Object.entries(data.jiraFields)
                    .map(([field, value]) => `${field}: ${value}`)
                    .join(', ');
                return `${message}\n  → ${fieldUpdates}`;
            }
            
            return message;
        }

        function truncateUrl(url, maxLength = 50) {
            if (url.length <= maxLength) return url;
            
            try {
                const urlObj = new URL(url);
                const domain = urlObj.hostname;
                const path = urlObj.pathname;
                
                if (`${domain}${path}`.length <= maxLength) {
                    return `${domain}${path}`;
                }
            } catch (e) {
                // Fall back to simple truncation if URL parsing fails
            }
            
            return url.substring(0, maxLength - 3) + '...';
        }

        function generateLogEntryHTML(timestamp, icon, type, message, data) {
            const typeClasses = {
                'info': 'text-info',
                'success': 'text-success',
                'warning': 'text-warning',
                'error': 'text-danger',
                'progress': 'text-primary'
            };
            
            const typeClass = typeClasses[type] || 'text-muted';
            const lines = message.split('\n');
            const mainMessage = lines[0];
            const details = lines.slice(1);
            
            let html = `
                <div class="log-entry mb-2" data-type="${type}">
                    <div class="d-flex align-items-start">
                        <span class="log-timestamp text-muted small me-2" style="min-width: 60px;">${timestamp}</span>
                        <span class="log-icon me-1">${icon}</span>
                        <div class="log-content flex-grow-1">
                            <div class="log-message ${typeClass}">${escapeHtml(mainMessage)}</div>
            `;
            
            if (details.length > 0) {
                html += `<div class="log-details text-muted small mt-1">`;
                details.forEach(detail => {
                    if (detail.trim()) {
                        html += `<div class="ps-3">${escapeHtml(detail)}</div>`;
                    }
                });
                html += `</div>`;
            }
            
            // Add structured data display if available
            if (data && typeof data === 'object') {
                html += generateStructuredDataHTML(data);
            }
            
            html += `
                        </div>
                    </div>
                </div>
            `;
            
            return html;
        }

        function generateStructuredDataHTML(data) {
            if (data.progress && typeof data.progress === 'object') {
                const { current, total, eta } = data.progress;
                return `
                    <div class="progress-info mt-2">
                        <div class="progress" style="height: 4px;">
                            <div class="progress-bar" role="progressbar" 
                                 style="width: ${(current/total)*100}%"></div>
                        </div>
                        <small class="text-muted">${current}/${total}${eta ? ` • ETA: ${eta}` : ''}</small>
                    </div>
                `;
            }
            
            if (data.json && typeof data.json === 'object') {
                return `
                    <details class="mt-2">
                        <summary class="small text-muted cursor-pointer">Raw Data</summary>
                        <pre class="small bg-light p-2 rounded mt-1 text-wrap">${JSON.stringify(data.json, null, 2)}</pre>
                    </details>
                `;
            }
            
            return '';
        }

        function escapeHtml(text) {
            if (typeof text !== 'string') return text;
            
            return text
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        // Enhanced addModalLogEntry function
        function addModalLogEntry(message, type = 'info', data = null) {
            const log = document.getElementById('processingLog');
            if (!log) return;
            
            const formatted = formatLogEntryWithStructure(message, type, data);
            
            // Create new log entry element
            const entryElement = document.createElement('div');
            entryElement.innerHTML = formatted.html;
            
            // Append to log with smooth animation
            const logEntry = entryElement.firstElementChild;
            logEntry.style.opacity = '0';
            logEntry.style.transform = 'translateY(-10px)';
            
            log.appendChild(logEntry);
            
            // Trigger fade-in animation
            requestAnimationFrame(() => {
                logEntry.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                logEntry.style.opacity = '1';
                logEntry.style.transform = 'translateY(0)';
            });
            
            // Auto-scroll to bottom
            log.scrollTop = log.scrollHeight;
            
            // Limit log entries to prevent memory issues
            const entries = log.querySelectorAll('.log-entry');
            if (entries.length > 100) {
                entries[0].remove();
            }
            
            return formatted;
        }
        
        // Update step status in modal
        function updateModalStep(stepName, status, message = '') {
            const stepEl = document.getElementById(`step-${stepName}`);
            if (stepEl) {
                stepEl.className = `step ${status}`;
                
                // Update status message
                stepEl.querySelector('.step-status').textContent = message;
                
                // Add or update timestamp
                let timestampEl = stepEl.querySelector('.step-timestamp');
                if (!timestampEl) {
                    timestampEl = document.createElement('div');
                    timestampEl.className = 'step-timestamp text-muted small';
                    stepEl.querySelector('.step-content').appendChild(timestampEl);
                }
                
                // Update timestamp with current time
                const now = new Date();
                const timeString = now.toLocaleTimeString('en-US', { 
                    hour12: false, 
                    hour: '2-digit', 
                    minute: '2-digit', 
                    second: '2-digit' 
                });
                timestampEl.textContent = `Last updated: ${timeString}`;
                
                if (status === 'in-progress') {
                    addModalLogEntry(`Starting: ${stepEl.querySelector('.step-title').textContent}`);
                } else if (status === 'completed') {
                    addModalLogEntry(`✓ Completed: ${stepEl.querySelector('.step-title').textContent}`, 'success');
                } else if (status === 'failed') {
                    addModalLogEntry(`✗ Failed: ${stepEl.querySelector('.step-title').textContent} - ${message}`, 'error');
                }
            }
        }
        
        // =============================================================================
        // ENHANCED MODAL LOGGING WITH RICH CONTEXT EXTRACTION
        // =============================================================================
        
        // Extract and format verification step details
        function formatVerificationLogEntry(data) {
            const url = data.context?.result?.linkedin_url || data.context?.linkedin_url;
            if (url) {
                return `Verifying LinkedIn URL: ${url}`;
            }
            return 'Verifying LinkedIn URL...';
        }

        // Extract and format ingestion step details
        function formatIngestionLogEntry(data) {
            const result = data.context?.result;
            if (!result) return 'Extracting profile data...';
            
            const details = [];
            if (result.profile_name) details.push(`Name: ${result.profile_name}`);
            if (result.current_title) details.push(`Title: ${result.current_title}`);
            if (result.current_company) details.push(`Company: ${result.current_company}`);
            if (result.location) details.push(`Location: ${result.location}`);
            
            if (details.length > 0) {
                return `Profile extracted - ${details.join(', ')}`;
            }
            return result.skipped ? 'Profile already exists' : 'Profile data extracted';
        }

        // Extract and format compatibility step details
        function formatCompatibilityLogEntry(data) {
            const result = data.context?.result;
            if (!result) return 'Checking role compatibility...';
            
            if (result.compatible_roles && Array.isArray(result.compatible_roles) && result.compatible_roles.length > 0) {
                const roleScores = result.compatible_roles
                    .map(role => `${role.role}: ${(role.confidence * 10).toFixed(1)}/10`)
                    .join(', ');
                return `Compatibility Results: ${roleScores}`;
            }
            
            const primaryRole = result.recommended_primary_role;
            if (primaryRole) {
                return `Best fit role identified: ${primaryRole}`;
            }
            
            return 'Role compatibility analysis completed';
        }

        // Extract and format scoring step details
        function formatScoringLogEntry(data) {
            const result = data.context?.result;
            if (!result) return 'AI scoring in progress...';
            
            const score = result.score ?? result.total_score;
            const role = result.role || result.suggested_role;
            
            if (score !== undefined && role) {
                return `AI Scoring Complete: ${score}/10 for ${role} role`;
            } else if (score !== undefined) {
                return `AI Scoring Complete: ${score}/10`;
            }
            
            return 'AI scoring completed';
        }

        // Extract and format JIRA update details
        function formatJiraLogEntry(data) {
            const result = data.context?.result;
            if (!result) return 'Updating JIRA with results...';
            
            const updates = [];
            if (result.fit_score) updates.push(`FIT Score: ${result.fit_score}`);
            if (result.fit_status) updates.push(`Status: ${result.fit_status}`);
            if (result.standing) updates.push(`Standing: ${result.standing}`);
            if (result.jira_status) updates.push(`Result: ${result.jira_status}`);
            
            if (updates.length > 0) {
                return `JIRA Updated - ${updates.join(', ')}`;
            }
            
            return 'JIRA fields updated successfully';
        }

        // Extract and format error details with retry information
        function formatErrorLogEntry(data, stepName) {
            const error = data.error || data.message;
            const errorType = data.error_type;
            const suggestedAction = data.suggested_action;
            
            let message = `${stepName} failed`;
            if (error) message += `: ${error}`;
            if (suggestedAction === 'retry_later') message += ' (retry in a few minutes)';
            if (suggestedAction === 'retry_immediately') message += ' (can retry now)';
            
            return message;
        }

        // Step icon animation handler
        function updateStepIcon(stepName, status) {
            const stepEl = document.getElementById(`step-${stepName}`);
            const iconEl = stepEl?.querySelector('.step-icon i');
            if (!iconEl) return;
            
            // Remove existing animation classes
            iconEl.classList.remove('fa-spin', 'fa-bounce', 'fa-fade');
            
            switch(status) {
                case 'in-progress':
                    // Set step-specific loading animation
                    switch(stepName) {
                        case 'verify':
                            iconEl.className = 'bi bi-link-45deg fa-spin';
                            break;
                        case 'ingest':
                            iconEl.className = 'bi bi-download fa-bounce';
                            break;
                        case 'compatibility':
                            iconEl.className = 'bi bi-cpu fa-fade';
                            break;
                        case 'score':
                            iconEl.className = 'bi bi-stars fa-spin';
                            break;
                        case 'update_jira':
                            iconEl.className = 'bi bi-upload fa-bounce';
                            break;
                        default:
                            iconEl.className = 'bi bi-hourglass-split fa-spin';
                    }
                    break;
                case 'completed':
                    iconEl.className = 'bi bi-check-circle-fill text-success';
                    break;
                case 'failed':
                    iconEl.className = 'bi bi-x-circle-fill text-danger';
                    break;
                default:
                    iconEl.className = 'bi bi-circle';
