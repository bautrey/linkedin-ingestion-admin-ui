        // Update step progress with details and ETA
        function updateStepProgress(stepId, progress, details = null, eta = null) {
            const stepElement = document.getElementById(stepId);
            if (!stepElement) return;
            
            // Update progress bar
            const progressBar = stepElement.querySelector('.progress-bar');
            if (progressBar) {
                const clampedProgress = Math.min(Math.max(progress, 0), 100);
                progressBar.style.width = `${clampedProgress}%`;
                progressBar.setAttribute('aria-valuenow', clampedProgress.toString());
                
                // Add striped animation for in-progress
                if (clampedProgress > 0 && clampedProgress < 100) {
                    progressBar.classList.add('progress-bar-striped', 'progress-bar-animated');
                } else {
                    progressBar.classList.remove('progress-bar-striped', 'progress-bar-animated');
                }
            }
            
            // Update details in step-status
            if (details) {
                const statusEl = stepElement.querySelector('.step-status');
                if (statusEl) {
                    statusEl.textContent = details;
                }
            }
            
            // Update ETA
            if (eta) {
                const etaEl = stepElement.querySelector('.step-eta');
                if (etaEl) {
                    etaEl.textContent = eta;
                    etaEl.style.opacity = '1';
                }
            }
        }

        // Show intermediate processing results
        function showIntermediateResult(stepId, result, type = 'info') {
            const stepElement = document.getElementById(stepId);
            if (!stepElement) return;
            
            let intermediateEl = stepElement.querySelector('.intermediate-results');
            if (!intermediateEl) {
                intermediateEl = document.createElement('div');
                intermediateEl.className = 'intermediate-results mt-2';
                intermediateEl.style.maxHeight = '120px';
                intermediateEl.style.overflowY = 'auto';
                stepElement.querySelector('.step-content').appendChild(intermediateEl);
            }
            
            const resultEl = document.createElement('div');
            const iconMap = {
                'error': 'exclamation-triangle text-danger',
                'success': 'check-circle text-success', 
                'warning': 'exclamation-circle text-warning',
                'info': 'info-circle text-primary'
            };
            
            resultEl.className = 'intermediate-result p-2 mb-1 rounded-2 bg-light border-start border-3';
            resultEl.style.borderLeftColor = type === 'error' ? 'var(--bs-danger)' : 
                                           type === 'success' ? 'var(--bs-success)' :
                                           type === 'warning' ? 'var(--bs-warning)' : 'var(--bs-primary)';
            resultEl.innerHTML = `
                <div class="d-flex align-items-start">
                    <i class="bi bi-${iconMap[type]} me-2 mt-1 flex-shrink-0"></i>
                    <div class="flex-grow-1">
                        <div class="small">${result}</div>
                        <div class="text-muted small">${new Date().toLocaleTimeString()}</div>
                    </div>
                </div>
            `;
            
            // Add with fade-in effect
            resultEl.style.opacity = '0';
            resultEl.style.transform = 'translateY(-10px)';
            intermediateEl.appendChild(resultEl);
            
            // Animate in
            setTimeout(() => {
                resultEl.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                resultEl.style.opacity = '1';
                resultEl.style.transform = 'translateY(0)';
            }, 10);
            
            // Limit to last 4 intermediate results
            while (intermediateEl.children.length > 4) {
                const firstChild = intermediateEl.firstChild;
                firstChild.style.transition = 'opacity 0.2s ease';
                firstChild.style.opacity = '0';
                setTimeout(() => {
                    if (firstChild.parentNode) {
                        intermediateEl.removeChild(firstChild);
                    }
                }, 200);
            }
            
            // Auto-scroll to bottom
            intermediateEl.scrollTop = intermediateEl.scrollHeight;
        }

        // Step-specific progress update functions
