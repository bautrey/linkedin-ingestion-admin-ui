        // Step timing and ETA calculation
        class StepTimer {
            constructor() {
                this.stepTimes = {
                    'verify': { avg: 3000, variance: 1000 },
                    'ingest': { avg: 5000, variance: 2000 },
                    'compatibility': { avg: 8000, variance: 3000 },
                    'score': { avg: 12000, variance: 5000 },
                    'update_jira': { avg: 4000, variance: 1500 }
                };
                this.stepStartTimes = {};
                this.stepProgress = {};
            }
            
            startStep(stepName) {
                this.stepStartTimes[stepName] = Date.now();
                this.stepProgress[stepName] = 0;
                // Create progress bar when step starts
                createStepProgressBar(`step-${stepName}`, 5);
                this.simulateProgress(stepName);
            }
            
            simulateProgress(stepName) {
                const stepTimes = this.stepTimes[stepName] || this.stepTimes['verify'];
                const totalTime = stepTimes.avg + (Math.random() - 0.5) * stepTimes.variance;
                const interval = totalTime / 20; // 20 updates to reach 100%
                
                const updateProgress = () => {
                    if (this.stepProgress[stepName] >= 95) return; // Stop at 95% until real completion
                    
                    this.stepProgress[stepName] += 5;
                    const progress = this.stepProgress[stepName];
                    const eta = this.getETA(stepName, progress);
                    
                    updateStepProgress(`step-${stepName}`, progress, null, eta);
                    
                    if (progress < 95) {
                        setTimeout(updateProgress, interval + (Math.random() - 0.5) * 1000);
                    }
                };
                
                setTimeout(updateProgress, interval);
            }
            
            getETA(stepName, currentProgress) {
                const startTime = this.stepStartTimes[stepName];
                if (!startTime || currentProgress <= 5) return null;
                
                const elapsed = Date.now() - startTime;
                const estimatedTotal = (elapsed / (currentProgress - 5)) * 95;
                const remaining = Math.max(0, estimatedTotal - elapsed);
                
                if (remaining < 1000) return 'Almost done...';
                if (remaining < 60000) return `~${Math.round(remaining / 1000)}s remaining`;
                return `~${Math.round(remaining / 60000)}m remaining`;
            }
        }

