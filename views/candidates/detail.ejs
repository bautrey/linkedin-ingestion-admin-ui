            if (data.context?.result?.skipped && progress >= 50) {
                showIntermediateResult('step-ingest', 'Profile already exists in database', 'info');
            }
        }

        function updateCompatibilityProgress(data, progress) {
            const roles = ['CIO', 'CTO', 'CISO'];
            const currentRoleIndex = Math.floor((progress / 100) * roles.length);
            const currentRole = roles[currentRoleIndex];
            
            if (currentRoleIndex < roles.length && progress < 90) {
                updateStepProgress('step-compatibility', progress, `Analyzing ${currentRole} compatibility...`);
            } else {
                updateStepProgress('step-compatibility', progress, 'Finalizing compatibility analysis...');
            }
            
            // Show individual role results as they complete
            if (data.context?.result?.compatible_roles && Array.isArray(data.context.result.compatible_roles)) {
                data.context.result.compatible_roles.forEach((roleResult, index) => {
                    const roleProgress = ((index + 1) / roles.length) * 100;
                    if (progress >= roleProgress) {
                        const confidence = (roleResult.confidence * 10).toFixed(1);
                        const compatible = roleResult.compatible ? '✓ Compatible' : '⚠ Not ideal fit';
                        showIntermediateResult('step-compatibility', 
                            `${roleResult.role}: ${confidence}/10 - ${compatible}`,
                            roleResult.compatible ? 'success' : 'warning');
                    }
                });
            }
        }

        function updateScoringProgress(data, progress) {
            const stages = [
                { threshold: 25, message: 'Analyzing profile content and experience...' },
                { threshold: 50, message: 'Evaluating technical qualifications...' },
                { threshold: 75, message: 'Calculating leadership assessment...' },
                { threshold: 90, message: 'Generating final score...' }
            ];
            
            stages.forEach(stage => {
                if (progress >= stage.threshold && progress < stage.threshold + 25) {
                    updateStepProgress('step-score', progress, stage.message);
