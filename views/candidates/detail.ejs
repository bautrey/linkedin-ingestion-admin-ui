            ];
            
            updateStepProgress('step-ingest', progress, 
                progress < 100 ? 'Extracting profile information...' : 'Profile data extracted');
            
            stages.forEach(stage => {
                if (progress >= stage.threshold && data.context?.result?.[stage.field]) {
                    const value = data.context.result[stage.field];
                    showIntermediateResult('step-ingest', 
                        `${stage.label}: ${value}${stage.suffix || ''}`, 'success');
