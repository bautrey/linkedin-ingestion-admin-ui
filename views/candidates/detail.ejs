                                            <td class="small">${role.reasoning || 'No reasoning provided'}</td>
                                        </tr>
                                    `).join('')}
                                </tbody>
                            </table>
                        </div>
                        
                        ${data.overall_assessment ? `
                            <div class="mt-3">
                                <strong>Overall Assessment:</strong>
                                <p class="text-muted mb-0">${data.overall_assessment}</p>
                            </div>
                        ` : ''}
                        
                        <div class="mt-3">
                            <small class="text-muted">
                                <i class="bi bi-clock"></i> Analysis completed in ${data.ai_response_time?.toFixed(1) || 'N/A'}s using ${data.model_used || 'AI'}
                                <br>
                                ${data.proceed_with_scoring ? 
                                    '<i class="bi bi-check-circle text-success"></i> Candidate passed compatibility screening and can proceed to detailed scoring' :
                                    '<i class="bi bi-x-circle text-danger"></i> Candidate did not pass compatibility screening'
                                }
                            </small>
                        </div>
                    </div>
                </div>
            `;
            
            container.innerHTML = html;
            container.style.display = 'block';
        }

        // =============================================================================
        // WEBSOCKET INTEGRATION FOR REAL-TIME UPDATES
        // =============================================================================

        // Global variables for WebSocket
        let socket = null;
        let currentExecutionId = null;

        // Initialize WebSocket connection
        function initializeWebSocket() {
            if (socket && socket.connected) {
                return; // Already connected
            }

            socket = io();

            socket.on('connect', () => {
                console.log('🔌 WebSocket connected for candidate processing updates');
                showToast('Connected to real-time updates', 'info', 2000);
            });

            socket.on('disconnect', () => {
                console.log('🔌 WebSocket disconnected');
            });

            // Listen for candidate processing events
            socket.on('candidate-start', (data) => {
                console.log('🎯 Processing started:', data);
                if (data.context && data.context.candidateKey === '<%= candidate.key %>') {
                    handleProcessingStart(data);
                }
            });

            socket.on('candidate-complete', (data) => {
                console.log('🎯 Processing completed:', data);
                if (data.context && data.context.candidateKey === '<%= candidate.key %>') {
                    handleProcessingComplete(data);
                }
            });

            // Listen for job status updates (from the job scheduler)
            socket.on('job-status-update', (data) => {
                console.log('📊 Job status update:', data);
                // Could be used for additional job-level updates if needed
            });
            
            // Listen for step-level processing events with enhanced logging
            socket.on('step-verify-start', (data) => {
                console.log('🔧 Step started: verify', data);
                if (data.jobName === '<%= candidate.key %>') {
                    updateEnhancedModalStep('verify', 'in-progress', 'Verifying LinkedIn URL...', data);
                    createStepProgressBar('step-verify', 0);
                    startVerificationProgress('step-verify', data);
                    stepTimer.startStep('verify');
                }
            });
            
            socket.on('step-verify-complete', (data) => {
                console.log('🔧 Step completed: verify', data);
                if (data.jobName === '<%= candidate.key %>') {
                    updateEnhancedModalStep('verify', 'completed', 'LinkedIn URL verified', data);
                    updateModalProgress(20);
                    
                    // Show intermediate results and complete progress
                    displayIntermediateVerificationResult(data);
                    updateStepProgressBar('step-verify', 100);
                    stepTimer.completeStep('verify');
                    
                    // Update the Processing Status card with verification timestamp
                    updateProcessingStepTimestamp('LinkedIn Profile Available', data.timestamp || new Date().toISOString());
                }
            });
            
            socket.on('step-ingest-start', (data) => {
                console.log('🔧 Step started: ingest', data);
                if (data.jobName === '<%= candidate.key %>') {
                    updateEnhancedModalStep('ingest', 'in-progress', 'Extracting profile data...', data);
                    createStepProgressBar('step-ingest', 0);
                    startIngestionProgress('step-ingest', data);
                    stepTimer.startStep('ingest');
                }
            });
            
            socket.on('step-ingest-complete', (data) => {
                console.log('🔧 Step completed: ingest', data);
                if (data.jobName === '<%= candidate.key %>') {
                    const message = data.context.result?.skipped ? 'Profile already exists' : 'Profile data ingested';
                    updateEnhancedModalStep('ingest', 'completed', message, data);
                    updateModalProgress(40);
                    
                    // Show intermediate results and complete progress
                    displayIntermediateIngestionResult(data);
                    updateStepProgressBar('step-ingest', 100);
                    stepTimer.completeStep('ingest');
                    
                    // Update the Processing Status card with ingestion timestamp
                    updateProcessingStepTimestamp('Profile Ingested', data.timestamp || new Date().toISOString());
                }
            });
            
            socket.on('step-check-compatibility-start', (data) => {
                console.log('🔧 Step started: compatibility', data);
                if (data.jobName === '<%= candidate.key %>') {
                    updateEnhancedModalStep('compatibility', 'in-progress', 'Checking role compatibility...', data);
                    createStepProgressBar('step-compatibility', 0);
                    startCompatibilityProgress('step-compatibility', data);
                    stepTimer.startStep('compatibility');
                }
            });
            
            socket.on('step-check-compatibility-complete', (data) => {
                console.log('🔧 Step completed: compatibility', data);
                console.log('🔧 DEBUG compatibility data:', data.context?.result);
                if (data.jobName === '<%= candidate.key %>') {
                    const bestRole = data.context.result?.recommended_primary_role || 'Unknown';
                    console.log('🔧 DEBUG bestRole extracted:', bestRole);
                    updateEnhancedModalStep('compatibility', 'completed', `Best fit: ${bestRole}`, data);
                    updateModalProgress(60);
                    
                    // Show intermediate results and complete progress
                    displayIntermediateCompatibilityResult(data);
                    updateStepProgressBar('step-compatibility', 100);
                    stepTimer.completeStep('compatibility');
                    
                    // Update the Processing Status card with compatibility timestamp
                    updateProcessingStepTimestamp('Compatibility Checked', data.timestamp || new Date().toISOString());
                }
            });
            
            socket.on('step-score-start', (data) => {
                console.log('🔧 Step started: scoring', data);
                if (data.jobName === '<%= candidate.key %>') {
                    updateEnhancedModalStep('score', 'in-progress', 'AI scoring in progress...', data);
                    createStepProgressBar('step-score', 0);
                    startScoringProgress('step-score', data);
                    stepTimer.startStep('score');
                }
            });
            
            socket.on('step-score-complete', (data) => {
                console.log('🔧 Step completed: scoring', data);
                if (data.jobName === '<%= candidate.key %>') {
                    const score = data.context.result?.score ?? 'Unknown';
                    const role = data.context.result?.role || 'Unknown';
                    updateEnhancedModalStep('score', 'completed', `Scored: ${score}/10 for ${role}`, data);
                    updateModalProgress(80);
                    
                    // Show intermediate results and complete progress
                    displayIntermediateScoringResult(data);
                    updateStepProgressBar('step-score', 100);
                    stepTimer.completeStep('score');
                    
                    // Update the Processing Status card with scoring timestamp
                    updateProcessingStepTimestamp('Scored', data.timestamp || new Date().toISOString());
                }
            });
            
            socket.on('step-update_jira-start', (data) => {
                console.log('🔧 Step started: JIRA update', data);
                if (data.jobName === '<%= candidate.key %>') {
                    updateEnhancedModalStep('update_jira', 'in-progress', 'Updating JIRA with results...', data);
                    createStepProgressBar('step-jira', 0);
                    startJiraProgress('step-jira', data);
                    stepTimer.startStep('jira');
                }
            });
            
            socket.on('step-update_jira-complete', (data) => {
                console.log('🔧 Step completed: JIRA update', data);
                if (data.jobName === '<%= candidate.key %>') {
                    const jiraStatus = data.context.result?.jira_status || 'Updated';
                    updateEnhancedModalStep('update_jira', 'completed', `JIRA ${jiraStatus}`, data);
                    updateModalProgress(100);
                    
                    // Show intermediate results and complete progress
                    displayIntermediateJiraResult(data);
                    updateStepProgressBar('step-jira', 100);
                    stepTimer.completeStep('jira');
                    
                    // Update the Processing Status card with JIRA update timestamp
                    updateProcessingStepTimestamp('JIRA Updated', data.timestamp || new Date().toISOString());
                }
            });
            
            // Generic step update listener for any other steps with enhanced logging
            socket.on('candidate-step-update', (data) => {
                console.log('🔧 Generic step update:', data);
                if (data.candidateKey === '<%= candidate.key %>') {
                    const stepName = data.stepName;
                    const status = data.status; // 'start', 'complete', 'error'
                    const message = data.message || '';
                    
                    if (status === 'start') {
                        updateEnhancedModalStep(stepName, 'in-progress', message, data);
                    } else if (status === 'complete') {
                        updateEnhancedModalStep(stepName, 'completed', message, data);
                    } else if (status === 'error') {
                        updateEnhancedModalStep(stepName, 'failed', message, data);
                    }
                }
            });

            // Enhanced error handling for external service failures
            socket.on('processing-error', (data) => {
                console.log('🚨 Processing error:', data);
                if (data.candidateKey === '<%= candidate.key %>' || data.executionId === currentExecutionId) {
                    displayProcessingError(data);
                }
            });
        }

        // Handle processing start event
        function handleProcessingStart(data) {
            currentExecutionId = data.executionId;
            showToast(`Processing started for ${data.candidateName}`, 'info', 3000);
            
            // Update all processing steps to show "in progress" state
            const steps = document.querySelectorAll('.processing-steps .step');
            steps.forEach(step => {
                const icon = step.querySelector('i');
                icon.className = 'bi bi-circle-fill text-warning';
                step.classList.remove('completed', 'pending');
                step.classList.add('processing');
            });
        }

        // Handle processing completion event  
        function handleProcessingComplete(data) {
            const duration = data.duration ? (data.duration / 1000).toFixed(1) : 'unknown time';
            
            if (data.success) {
                showToast(`Processing completed successfully in ${duration}s! Page will reload in 3 seconds.`, 'success', 3000);
                
                // Update all steps to completed
                const steps = document.querySelectorAll('.processing-steps .step');
                steps.forEach(step => {
                    const icon = step.querySelector('i');
                    icon.className = 'bi bi-check-circle-fill text-success';
                    step.classList.remove('pending', 'processing');
                    step.classList.add('completed');
                });
                
                // Reload page after a delay to show updated data
                setTimeout(() => {
                    location.reload();
                }, 3000);
                
            } else {
                showToast(`Processing completed with issues in ${duration}. Check results below.`, 'warning', 5000);
                
                // Update steps based on individual results
                if (data.results && data.results.steps) {
                    updateIndividualSteps(data.results.steps);
                }
                
                // Reload page after delay
                setTimeout(() => {
                    location.reload();
                }, 5000);
            }
            
            currentExecutionId = null;
        }

        // Handle processing error event
        function handleProcessingError(data) {
            const duration = data.duration ? (data.duration / 1000).toFixed(1) : 'unknown time';
            showToast(`Processing failed after ${duration}: ${data.error}`, 'error', 8000);
            
            // Update steps to show error state
            const steps = document.querySelectorAll('.processing-steps .step');
            steps.forEach(step => {
                const icon = step.querySelector('i');
                icon.className = 'bi bi-x-circle-fill text-danger';
                step.classList.remove('completed', 'pending', 'processing');
                step.classList.add('error');
            });
            
            currentExecutionId = null;
        }

        // Display enhanced error messages with actionable guidance
        function displayProcessingError(errorData) {
            console.log('🚨 Displaying enhanced error:', errorData);
            
            // Create user-friendly error message
            const errorMessage = getActionableErrorMessage(errorData);
            
            // Show error toast with retry guidance
            showToast(errorMessage.toast, 'error', 10000);
            
            // Add detailed error message to modal if it's open
            const modal = document.getElementById('processing-modal');
            if (modal && modal.style.display !== 'none') {
                const modalBody = document.getElementById('processing-modal-body') || document.querySelector('#processing-modal .modal-body');
                if (modalBody) {
                    const errorDiv = document.createElement('div');
                    errorDiv.className = 'alert alert-warning mt-3';
                    errorDiv.innerHTML = errorMessage.modal;
                    modalBody.appendChild(errorDiv);
                }
            }
            
            // Update processing steps to show error state
            const steps = document.querySelectorAll('.processing-steps .step');
            steps.forEach(step => {
                const icon = step.querySelector('i');
                icon.className = 'bi bi-exclamation-triangle-fill text-warning';
                step.classList.remove('completed', 'pending', 'processing');
                step.classList.add('error');
            });
        }

        // Generate user-friendly error messages based on error type
        function getActionableErrorMessage(errorData) {
            const errorType = errorData.error_type;
            const suggestedAction = errorData.suggested_action;
            const retryEstimate = errorData.retry_estimate;
            
            let toast, modal;
            
            switch (errorType) {
                case 'external_service_failure':
                    toast = `LinkedIn services unavailable. ${retryEstimate ? `Try again in ${retryEstimate}` : 'Please try again later'}`;
                    modal = `
                        <h6><i class="bi bi-exclamation-triangle"></i> LinkedIn Services Unavailable</h6>
                        <p><strong>Issue:</strong> ${errorData.user_message || 'LinkedIn API servers are currently down'}</p>
                        <p><strong>Suggested Action:</strong> ${getActionText(suggestedAction)}</p>
                        ${retryEstimate ? `<p><strong>Estimated Recovery:</strong> ${retryEstimate}</p>` : ''}
                        <button class="btn btn-sm btn-outline-primary" onclick="retryProcessing()">Try Again</button>
                    `;
                    break;
                    
                case 'rate_limiting':
                    toast = `LinkedIn API rate limit reached. Please wait ${retryEstimate || '1 hour'} before retrying`;
                    modal = `
                        <h6><i class="bi bi-clock"></i> Rate Limit Reached</h6>
                        <p><strong>Issue:</strong> LinkedIn API rate limit has been exceeded</p>
                        <p><strong>Suggested Action:</strong> ${getActionText(suggestedAction)}</p>
                        <p><strong>Wait Time:</strong> ${retryEstimate || '1 hour'}</p>
                        <button class="btn btn-sm btn-outline-primary" onclick="retryProcessing()" disabled>Try Again (Wait Required)</button>
                    `;
                    break;
                    
                case 'authentication_issue':
                    toast = 'LinkedIn authentication expired. Please contact administrator';
                    modal = `
                        <h6><i class="bi bi-key"></i> Authentication Issue</h6>
                        <p><strong>Issue:</strong> LinkedIn API credentials need to be refreshed</p>
                        <p><strong>Suggested Action:</strong> Contact administrator to refresh API credentials</p>
                        <button class="btn btn-sm btn-outline-secondary" onclick="contactAdmin()">Contact Admin</button>
                    `;
                    break;
                    
                default:
                    toast = `Processing failed: ${errorData.user_message || 'Unknown error occurred'}`;
                    modal = `
                        <h6><i class="bi bi-exclamation-circle"></i> Processing Error</h6>
                        <p><strong>Issue:</strong> ${errorData.user_message || 'An unexpected error occurred'}</p>
                        <p><strong>Suggested Action:</strong> ${getActionText(suggestedAction) || 'Please try again or contact support'}</p>
                        <button class="btn btn-sm btn-outline-primary" onclick="retryProcessing()">Try Again</button>
                    `;
            }
            
            return { toast, modal };
        }

        // Convert suggested action codes to user-friendly text
        function getActionText(action) {
            switch (action) {
                case 'retry_later':
                    return 'Please wait and try again later';
                case 'retry_immediately':
                    return 'You can retry immediately';
                case 'contact_admin':
                    return 'Contact administrator for assistance';
                case 'check_status':
                    return 'Check LinkedIn status page for updates';
                default:
                    return 'Please try again or contact support';
            }
        }

        // Retry processing function
        function retryProcessing() {
            // Close any error modals
            const errorAlerts = document.querySelectorAll('.alert-warning');
            errorAlerts.forEach(alert => alert.remove());
            
            // Restart processing
            startProcessing();
        }

        // Contact admin function (placeholder)
        function contactAdmin() {
            // This could open a support ticket or email
            showToast('Please contact your administrator for LinkedIn API credential refresh', 'info', 5000);
        }

        // Update individual processing steps based on results
        function updateIndividualSteps(stepResults) {
            const stepElements = document.querySelectorAll('.processing-steps .step');
            const stepNames = ['LinkedIn Profile Available', 'Profile Ingested', 'Compatibility Checked', 'Scored', 'JIRA Updated'];
            
            stepResults.forEach((result, index) => {
                if (index < stepElements.length) {
                    const stepElement = stepElements[index];
                    const icon = stepElement.querySelector('i');
                    
                    if (result.success) {
                        icon.className = 'bi bi-check-circle-fill text-success';
                        stepElement.classList.add('completed');
                    } else {
                        icon.className = 'bi bi-x-circle-fill text-danger';
                        stepElement.classList.add('error');
                    }
                    
                    stepElement.classList.remove('pending', 'processing');
                }
            });
        }

        // Update processing step timestamp in the Processing Status card
        function updateProcessingStepTimestamp(stepName, timestamp, action = null) {
            const stepElements = document.querySelectorAll('.processing-steps .step');
            
            stepElements.forEach(stepElement => {
                const stepSpan = stepElement.querySelector('span');
                if (stepSpan && stepSpan.textContent.trim() === stepName) {
                    // Mark step as completed
                    const icon = stepElement.querySelector('i');
                    icon.className = 'bi bi-check-circle-fill text-success';
                    stepElement.classList.remove('pending', 'processing');
                    stepElement.classList.add('completed');
                    
                    // Add or update timestamp
                    let timestampDiv = stepElement.querySelector('.small.text-muted');
                    if (!timestampDiv) {
                        timestampDiv = document.createElement('div');
                        timestampDiv.className = 'small text-muted mt-1';
                        stepElement.querySelector('div').appendChild(timestampDiv);
                    }
                    
                    const formattedTime = new Date(timestamp).toLocaleString();
                    
                    // Determine action text based on step name if not provided
                    if (!action) {
                        if (stepName === 'LinkedIn Profile Available') action = 'Verified';
                        else if (stepName === 'Profile Ingested') action = 'Ingested';
                        else if (stepName === 'Compatibility Checked') action = 'Checked';
                        else if (stepName === 'Scored') action = 'Scored';
                        else if (stepName === 'JIRA Updated') action = 'Updated';
                        else action = 'Completed';
                    }
                    
                    timestampDiv.innerHTML = `<i class="bi bi-clock me-1"></i>${action}: ${formattedTime}`;
                }
            });
        }

        // Helper function to update processing steps when starting
        function updateProcessingStepsForStart(candidateKey, executionId) {
            currentExecutionId = executionId;
            
            // Add visual indicator that processing is starting
            const processingCard = document.querySelector('.card .card-header h5 i.bi-gear');
            if (processingCard) {
                const cardBody = processingCard.closest('.card').querySelector('.card-body');
                
                // Add a processing indicator
                const indicator = document.createElement('div');
                indicator.id = 'processing-indicator';
                indicator.className = 'alert alert-info mb-3';
                indicator.innerHTML = `
                    <div class="d-flex align-items-center">
                        <div class="spinner-border spinner-border-sm me-2" role="status">
                            <span class="visually-hidden">Processing...</span>
                        </div>
                        <div>
                            <strong>Processing in progress...</strong><br>
                            <small>Real-time updates will appear below. Execution ID: ${executionId.substring(0, 12)}...</small>
                        </div>
                    </div>
                `;
                
                // Remove any existing indicator
                const existing = document.getElementById('processing-indicator');
                if (existing) existing.remove();
                
                // Add new indicator at the top
                cardBody.insertBefore(indicator, cardBody.firstChild);
            }
        }

        // Initialize WebSocket on page load
        document.addEventListener('DOMContentLoaded', function() {
            // Small delay to ensure DOM is fully loaded
            setTimeout(initializeWebSocket, 500);
        });

        // Cleanup on page unload
        window.addEventListener('beforeunload', function() {
            if (socket) {
                socket.disconnect();
            }
        });

    </script>

