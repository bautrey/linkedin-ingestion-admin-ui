        function updateIngestionProgress(data, progress) {
            const stages = [
                { threshold: 20, field: 'profile_name', label: 'Profile name' },
                { threshold: 40, field: 'current_title', label: 'Current role' },
                { threshold: 60, field: 'current_company', label: 'Company' },
