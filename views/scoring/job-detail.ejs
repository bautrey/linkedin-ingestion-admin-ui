<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - LinkedIn Ingestion Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/app.css" rel="stylesheet">
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="sidebar-wrapper px-0">
                <%- include('../partials/sidebar') %>
            </div>
            
            <!-- Main Content -->
            <div class="main-content">
                <%- include('../partials/header', { pageTitle: title }) %>
                
                <div class="container-fluid py-4">
                    <!-- Page Header -->
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="d-flex align-items-center">
                            <a href="/scoring" class="btn btn-outline-secondary me-3">
                                <i class="bi bi-arrow-left"></i> Back to Scoring
                            </a>
                            <div>
                                <h2 class="fw-bold mb-1">Scoring Job Details</h2>
                                <p class="text-muted mb-0">
                                    <i class="bi bi-hash"></i> Job ID: <%= job.job_id || 'Unknown' %>
                                </p>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <% if (job.status === 'failed') { %>
                                <button class="btn btn-outline-warning" onclick="retryJob('<%= job.job_id %>')">
                                    <i class="bi bi-arrow-clockwise"></i> Retry Job
                                </button>
                            <% } %>
                            <% if (job.profile_id) { %>
                                <a href="/profiles/<%= job.profile_id %>" class="btn btn-outline-primary">
                                    <i class="bi bi-person"></i> View Profile
                                </a>
                            <% } %>
                        </div>
                    </div>

                    <div class="row">
                        <!-- Job Status Card -->
                        <div class="col-md-8">
                            <div class="card border-0 shadow-sm mb-4">
                                <div class="card-header bg-white border-0">
                                    <h5 class="mb-0 fw-bold">
                                        <i class="bi bi-info-circle text-primary"></i> Job Status
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="row mb-3">
                                        <div class="col-md-3">
                                            <strong>Status:</strong>
                                        </div>
                                        <div class="col-md-9">
                                            <% if (job.status === 'completed') { %>
                                                <span class="badge bg-success fs-6">
                                                    <i class="bi bi-check-circle"></i> Completed
                                                </span>
                                            <% } else if (job.status === 'pending') { %>
                                                <span class="badge bg-warning fs-6">
                                                    <i class="bi bi-clock"></i> Pending
                                                </span>
                                            <% } else if (job.status === 'running') { %>
                                                <span class="badge bg-info fs-6">
                                                    <i class="bi bi-play-circle"></i> Running
                                                </span>
                                            <% } else if (job.status === 'failed') { %>
                                                <span class="badge bg-danger fs-6">
                                                    <i class="bi bi-x-circle"></i> Failed
                                                </span>
                                            <% } else { %>
                                                <span class="badge bg-secondary fs-6">
                                                    <i class="bi bi-question-circle"></i> <%= job.status || 'Unknown' %>
                                                </span>
                                            <% } %>
                                        </div>
                                    </div>

                                    <div class="row mb-3">
                                        <div class="col-md-3">
                                            <strong>Created:</strong>
                                        </div>
                                        <div class="col-md-9">
                                            <%= job.created_at ? new Date(job.created_at).toLocaleString() : 'Unknown' %>
                                        </div>
                                    </div>

                                    <% if (job.started_at) { %>
                                        <div class="row mb-3">
                                            <div class="col-md-3">
                                                <strong>Started:</strong>
                                            </div>
                                            <div class="col-md-9">
                                                <%= new Date(job.started_at).toLocaleString() %>
                                            </div>
                                        </div>
                                    <% } %>

                                    <% if (job.completed_at) { %>
                                        <div class="row mb-3">
                                            <div class="col-md-3">
                                                <strong>Completed:</strong>
                                            </div>
                                            <div class="col-md-9">
                                                <%= new Date(job.completed_at).toLocaleString() %>
                                            </div>
                                        </div>
                                    <% } %>

                                    <% if (job.failed_at) { %>
                                        <div class="row mb-3">
                                            <div class="col-md-3">
                                                <strong>Failed:</strong>
                                            </div>
                                            <div class="col-md-9">
                                                <%= new Date(job.failed_at).toLocaleString() %>
                                            </div>
                                        </div>
                                    <% } %>
                                </div>
                            </div>

                            <!-- Results Card -->
                            <% if (job.result || job.error) { %>
                                <div class="card border-0 shadow-sm mb-4">
                                    <div class="card-header bg-white border-0">
                                        <h5 class="mb-0 fw-bold">
                                            <% if (job.result) { %>
                                                <i class="bi bi-award text-success"></i> Scoring Results
                                            <% } else { %>
                                                <i class="bi bi-exclamation-triangle text-danger"></i> Error Details
                                            <% } %>
                                        </h5>
                                    </div>
                                    <div class="card-body">
                                        <% if (job.result) { %>
                                            <!-- Enhanced Score Breakdown Display -->
                                            <% if (job.result.parsed_score && job.result.parsed_score.score_breakdown) { %>
                                                <div class="mb-4">
                                                    <h6 class="fw-bold mb-3">
                                                        <i class="bi bi-graph-up text-primary"></i> Score Breakdown
                                                    </h6>
                                                    <div class="row g-3">
                                                        <% Object.entries(job.result.parsed_score.score_breakdown).forEach(([category, scoreData]) => { %>
                                                            <div class="col-md-6">
                                                                <div class="card h-100 border-0 bg-light">
                                                                    <div class="card-body p-3">
                                                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                                                            <h6 class="card-title mb-0 text-capitalize">
                                                                                <%= category.replace(/_/g, ' ') %>
                                                                            </h6>
                                                            <% 
                                                            // Enhanced format only - expect {score: number, reasoning: string}
                                                            let score = scoreData.score;
                                                            let badgeClass = score >= 8 ? 'bg-success' : score >= 5 ? 'bg-warning' : 'bg-danger';
                                                            %>
                                                            <span class="badge <%= badgeClass %> px-2 py-1">
                                                                <%= score.toFixed(1) %>
                                                            </span>
                                                        </div>
                                                        <div class="reasoning-section">
                                                            <button class="btn btn-link p-0 text-start reasoning-toggle" 
                                                                    type="button" 
                                                                    data-bs-toggle="collapse" 
                                                                    data-bs-target="#reasoning-<%= category %>"
                                                                    aria-expanded="false">
                                                                <i class="bi bi-chevron-right"></i> Show Reasoning
                                                            </button>
                                                            <div class="collapse mt-2" id="reasoning-<%= category %>">
                                                                <small class="text-muted d-block">
                                                                    <i class="bi bi-quote"></i>
                                                                    <%= scoreData.reasoning %>
                                                                </small>
                                                            </div>
                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        <% }); %>
                                                    </div>
                                                </div>
                                            <% } %>
                                            
                                            <!-- Overall Score and Verdict -->
                                            <% if (job.result.parsed_score && (job.result.parsed_score.total_score || job.result.parsed_score.fit_verdict)) { %>
                                                <div class="mb-4">
                                                    <h6 class="fw-bold mb-3">
                                                        <i class="bi bi-trophy text-warning"></i> Overall Assessment
                                                    </h6>
                                                    <div class="row g-3">
                                                        <% if (job.result.parsed_score.total_score !== undefined) { %>
                                                            <div class="col-md-4">
                                                                <div class="card border-0 bg-primary bg-opacity-10">
                                                                    <div class="card-body text-center">
                                                                        <div class="display-4 fw-bold text-primary">
                                                                            <%= job.result.parsed_score.total_score %>
                                                                        </div>
                                                                        <small class="text-muted">Total Score</small>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        <% } %>
                                                        <% if (job.result.parsed_score.fit_verdict) { %>
                                                            <div class="col-md-8">
                                                                <div class="card border-0 bg-light">
                                                                    <div class="card-body">
                                                                        <h6 class="card-title">Fit Verdict</h6>
                                                                        <p class="card-text mb-0">
                                                                            <strong><%= job.result.parsed_score.fit_verdict %></strong>
                                                                        </p>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        <% } %>
                                                    </div>
                                                </div>
                                            <% } %>
                                            
                                            <!-- Rationale -->
                                            <% if (job.result.parsed_score && job.result.parsed_score.rationale) { %>
                                                <div class="mb-4">
                                                    <h6 class="fw-bold mb-3">
                                                        <i class="bi bi-lightbulb text-info"></i> Rationale
                                                    </h6>
                                                    <div class="card border-0 bg-light">
                                                        <div class="card-body">
                                                            <p class="mb-0"><%= job.result.parsed_score.rationale %></p>
                                                        </div>
                                                    </div>
                                                </div>
                                            <% } %>
                                            
                                            <!-- Raw Data (Collapsible) -->
                                            <div class="mb-4">
                                                <button class="btn btn-outline-secondary btn-sm" 
                                                        type="button" 
                                                        data-bs-toggle="collapse" 
                                                        data-bs-target="#rawData"
                                                        aria-expanded="false">
                                                    <i class="bi bi-code-square"></i> Show Raw Response Data
                                                </button>
                                                <div class="collapse mt-3" id="rawData">
                                                    <pre class="bg-light p-3 rounded small"><%= JSON.stringify(job.result, null, 2) %></pre>
                                                </div>
                                            </div>
                                        <% } %>
                                        <% if (job.error) { %>
                                            <div class="alert alert-danger">
                                                <strong>Error:</strong> <%= job.error %>
                                            </div>
                                        <% } %>
                                    </div>
                                </div>
                            <% } %>
                        </div>

                        <!-- Job Metadata -->
                        <div class="col-md-4">
                            <div class="card border-0 shadow-sm mb-4">
                                <div class="card-header bg-white border-0">
                                    <h6 class="mb-0 fw-bold">Job Metadata</h6>
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <small class="text-muted">Job ID</small>
                                        <div class="fw-medium small font-monospace">
                                            <%= job.job_id || 'Unknown' %>
                                        </div>
                                    </div>

                                    <% if (job.profile_id) { %>
                                        <div class="mb-3">
                                            <small class="text-muted">Profile ID</small>
                                            <div class="fw-medium small font-monospace">
                                                <%= job.profile_id %>
                                            </div>
                                        </div>
                                    <% } %>

                                    <% if (job.template_id) { %>
                                        <div class="mb-3">
                                            <small class="text-muted">Template ID</small>
                                            <div class="fw-medium small font-monospace">
                                                <%= job.template_id %>
                                            </div>
                                        </div>
                                    <% } %>
                                </div>
                            </div>

                            <!-- Actions Card -->
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-white border-0">
                                    <h6 class="mb-0 fw-bold">Actions</h6>
                                </div>
                                <div class="card-body">
                                    <div class="d-grid gap-2">
                                        <button class="btn btn-outline-primary" onclick="refreshJob()">
                                            <i class="bi bi-arrow-clockwise"></i> Refresh Status
                                        </button>
                                        
                                        <% if (job.status === 'failed') { %>
                                            <button class="btn btn-outline-warning" onclick="retryJob('<%= job.job_id %>')">
                                                <i class="bi bi-arrow-clockwise"></i> Retry Job
                                            </button>
                                        <% } %>

                                        <% if (job.profile_id) { %>
                                            <a href="/profiles/<%= job.profile_id %>" class="btn btn-outline-secondary">
                                                <i class="bi bi-person"></i> View Profile
                                            </a>
                                        <% } %>

                                        <a href="/scoring" class="btn btn-outline-secondary">
                                            <i class="bi bi-arrow-left"></i> Back to Scoring
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/app.js"></script>
    <script>
        function refreshJob() {
            location.reload();
        }

        function retryJob(jobId) {
            if (confirm('Are you sure you want to retry this scoring job?')) {
                fetch(`/api/scoring-jobs/${jobId}/retry`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => response.json())
                .then(result => {
                    if (result.success) {
                        showNotification('Job retry started successfully', 'success');
                        setTimeout(() => {
                            location.reload();
                        }, 2000);
                    } else {
                        showNotification('Failed to retry job: ' + result.message, 'error');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    showNotification('Error retrying job', 'error');
                });
            }
        }

        // Auto-refresh for pending/running jobs
        document.addEventListener('DOMContentLoaded', function() {
            const jobStatus = '<%= job.status %>';
            if (jobStatus === 'pending' || jobStatus === 'running') {
                // Refresh every 10 seconds for active jobs
                setTimeout(() => {
                    location.reload();
                }, 10000);
            }
            
            // Enhanced reasoning toggle behavior
            document.querySelectorAll('.reasoning-toggle').forEach(button => {
                button.addEventListener('click', function() {
                    const chevron = this.querySelector('i.bi-chevron-right, i.bi-chevron-down');
                    const isExpanded = this.getAttribute('aria-expanded') === 'true';
                    
                    if (isExpanded) {
                        chevron.classList.remove('bi-chevron-down');
                        chevron.classList.add('bi-chevron-right');
                        this.innerHTML = this.innerHTML.replace('Hide Reasoning', 'Show Reasoning');
                    } else {
                        chevron.classList.remove('bi-chevron-right');
                        chevron.classList.add('bi-chevron-down');
                        this.innerHTML = this.innerHTML.replace('Show Reasoning', 'Hide Reasoning');
                    }
                });
            });
        });
    </script>
</body>
</html>
